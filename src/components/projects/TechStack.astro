---
interface Props {
  techList: string[];
}

const { techList } = Astro.props;

// Icon mappings — devicon CDN or Simple Icons CDN
const DEVICON_BASE = 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons';
const SIMPLEICONS_BASE = 'https://cdn.simpleicons.org';

function devicon(name: string, variant = 'original') {
  return `${DEVICON_BASE}/${name}/${name}-${variant}.svg`;
}

function simpleicon(slug: string, color = '888888') {
  return `${SIMPLEICONS_BASE}/${slug}/${color}`;
}

// Map normalized key → { url, displayName }
const iconMap: Record<string, { url: string; display: string }> = {
  typescript:      { url: devicon('typescript'),      display: 'TypeScript' },
  javascript:      { url: devicon('javascript'),      display: 'JavaScript' },
  python:          { url: devicon('python'),           display: 'Python' },
  c:               { url: devicon('c'),                display: 'C' },
  java:            { url: devicon('java'),             display: 'Java' },
  html:            { url: devicon('html5'),            display: 'HTML' },
  css:             { url: devicon('css3'),             display: 'CSS' },
  php:             { url: devicon('php'),              display: 'PHP' },
  react:           { url: devicon('react'),            display: 'React' },
  'react native':  { url: devicon('react'),            display: 'React Native' },
  reactnative:     { url: devicon('react'),            display: 'React Native' },
  'next.js':       { url: devicon('nextjs'),           display: 'Next.js' },
  nextjs:          { url: devicon('nextjs'),           display: 'Next.js' },
  astro:           { url: simpleicon('astro'),         display: 'Astro' },
  tailwindcss:     { url: devicon('tailwindcss'),      display: 'TailwindCSS' },
  tailwind:        { url: devicon('tailwindcss'),      display: 'TailwindCSS' },
  vite:            { url: devicon('vitejs'),           display: 'Vite' },
  vitejs:          { url: devicon('vitejs'),           display: 'Vite' },
  expo:            { url: simpleicon('expo'),          display: 'Expo' },
  android:         { url: devicon('android'),          display: 'Android' },
  'node.js':       { url: devicon('nodejs'),           display: 'Node.js' },
  nodejs:          { url: devicon('nodejs'),           display: 'Node.js' },
  express:         { url: devicon('express'),          display: 'Express' },
  fastapi:         { url: devicon('fastapi'),          display: 'FastAPI' },
  flask:           { url: devicon('flask'),            display: 'Flask' },
  deno:            { url: devicon('denojs'),           display: 'Deno' },
  postgresql:      { url: devicon('postgresql'),       display: 'PostgreSQL' },
  postgres:        { url: devicon('postgresql'),       display: 'PostgreSQL' },
  mongodb:         { url: devicon('mongodb'),          display: 'MongoDB' },
  sqlite:          { url: devicon('sqlite'),           display: 'SQLite' },
  mysql:           { url: devicon('mysql'),            display: 'MySQL' },
  supabase:        { url: devicon('supabase'),         display: 'Supabase' },
  redis:           { url: devicon('redis'),            display: 'Redis' },
  firebase:        { url: devicon('firebase'),         display: 'Firebase' },
  websockets:      { url: simpleicon('websocket'),     display: 'WebSockets' },
  cloudflareworkers:{ url: simpleicon('cloudflare'),  display: 'Cloudflare' },
  openai:          { url: simpleicon('openai'),        display: 'OpenAI' },
  'openai api':    { url: simpleicon('openai'),        display: 'OpenAI' },
  figma:           { url: devicon('figma'),            display: 'Figma' },
  blender:         { url: devicon('blender'),          display: 'Blender' },
  git:             { url: devicon('git'),              display: 'Git' },
  github:          { url: simpleicon('github'),        display: 'GitHub' },
  docker:          { url: devicon('docker'),           display: 'Docker' },
  linux:           { url: devicon('linux'),            display: 'Linux' },
  ubuntu:          { url: devicon('ubuntu'),           display: 'Ubuntu' },
  aws:             { url: devicon('amazonwebservices', 'original-wordmark'), display: 'AWS' },
  amazonwebservices:{ url: devicon('amazonwebservices', 'original-wordmark'), display: 'AWS' },
  vercel:          { url: simpleicon('vercel'),        display: 'Vercel' },
  postman:         { url: devicon('postman'),          display: 'Postman' },
  'vs code':       { url: devicon('vscode'),           display: 'VS Code' },
  vscode:          { url: devicon('vscode'),           display: 'VS Code' },
  jetbrains:       { url: devicon('jetbrains'),        display: 'JetBrains' },
  linear:          { url: simpleicon('linear'),        display: 'Linear' },
  google:          { url: devicon('google'),           display: 'Google APIs' },
};

// Category buckets — order matters, first match wins
const categories: { label: string; keys: string[] }[] = [
  {
    label: 'Languages',
    keys: ['typescript', 'javascript', 'python', 'java', 'c', 'html', 'css', 'php'],
  },
  {
    label: 'Frontend',
    keys: ['react', 'next.js', 'nextjs', 'astro', 'tailwindcss', 'tailwind', 'vite', 'vitejs'],
  },
  {
    label: 'Mobile',
    keys: ['react native', 'reactnative', 'expo', 'android'],
  },
  {
    label: 'Backend',
    keys: ['fastapi', 'node.js', 'nodejs', 'express', 'flask', 'deno', 'websockets', 'cloudflareworkers'],
  },
  {
    label: 'Database',
    keys: ['postgresql', 'postgres', 'mongodb', 'sqlite', 'mysql', 'supabase', 'redis', 'firebase'],
  },
  {
    label: 'AI',
    keys: ['openai', 'openai api'],
  },
  {
    label: 'Design',
    keys: ['figma', 'blender', 'photoshop', 'illustrator', 'canva'],
  },
  {
    label: 'Tools',
    keys: [
      'git', 'github', 'docker', 'linux', 'ubuntu', 'aws', 'amazonwebservices',
      'vercel', 'postman', 'vs code', 'vscode', 'jetbrains', 'linear', 'google',
    ],
  },
];

function normalize(t: string): string {
  return t.toLowerCase().replace(/\s+/g, match => (match ? ' ' : '')).trim();
}

// Deduplicate and bucket
type Chip = { display: string; iconUrl: string };
const grouped: Record<string, Chip[]> = {};
const seenDisplay = new Set<string>();

for (const tech of techList) {
  const key = normalize(tech);
  const mapping = iconMap[key];
  const displayName = mapping?.display ?? tech;
  const iconUrl = mapping?.url ?? null;

  if (seenDisplay.has(displayName)) continue;
  seenDisplay.add(displayName);

  let placed = false;
  for (const cat of categories) {
    if (cat.keys.includes(key)) {
      if (!grouped[cat.label]) grouped[cat.label] = [];
      grouped[cat.label].push({ display: displayName, iconUrl: iconUrl ?? '' });
      placed = true;
      break;
    }
  }

  if (!placed) {
    if (!grouped['Other']) grouped['Other'] = [];
    grouped['Other'].push({ display: displayName, iconUrl: iconUrl ?? '' });
  }
}

const orderedLabels = [
  ...categories.map(c => c.label).filter(l => grouped[l]?.length),
  ...(grouped['Other'] ? ['Other'] : []),
];
---

<section class="techstack-section">
  <div class="text-label mb-6" style="color: var(--muted-foreground);">Stack</div>

  <div class="categories-wrapper">
    {orderedLabels.map(label => (
      <div class="category-block">
        <div class="category-label">{label}</div>
        <div class="chips-row">
          {grouped[label].map(chip => (
            <div class="chip">
              {chip.iconUrl && (
                <img
                  src={chip.iconUrl}
                  alt={chip.display}
                  width="18"
                  height="18"
                  class="chip-icon"
                  loading="lazy"
                />
              )}
              <span class="chip-name">{chip.display}</span>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .techstack-section {
    margin-bottom: 3rem;
  }

  .categories-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .category-label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted-foreground);
    margin-bottom: 0.5rem;
  }

  .chips-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 9999px;
    background: var(--muted);
    cursor: default;
    transition: background 150ms ease;
  }

  .chip:hover {
    background: var(--secondary);
  }

  .chip-icon {
    width: 18px;
    height: 18px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .chip-name {
    font-size: 0.75rem;
    font-weight: 450;
    color: var(--foreground);
    letter-spacing: 0.01em;
    white-space: nowrap;
  }
</style>
