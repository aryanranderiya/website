+										<ToolIcon src={tool.icon} name={tool.name} size={64} />
+										<h2 className="text-[20px] font-semibold tracking-[-0.03em] text-[var(--text-primary)] leading-[1.2] mt-3 mb-1.5 text-center">
+											{tool.name}
