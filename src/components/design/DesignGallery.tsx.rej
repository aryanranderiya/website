+				className="absolute bottom-5 left-1/2 -translate-x-1/2 text-[12px] tabular-nums tracking-[0.04em] pointer-events-none select-none text-[color-mix(in_srgb,var(--foreground)_50%,transparent)]"
+			>
+				{index + 1} / {total}
+			</div>
+		</motion.div>
+	);
