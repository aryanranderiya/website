@@ -64,12 +75,12 @@ export default function CommandK() {
-  // Open on ⌘K / Ctrl+K
-  useEffect(() => {
-    function onKeyDown(e: KeyboardEvent) {
-      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
-        e.preventDefault();
-        setOpen(prev => !prev);
-      }
-      if (e.key === 'Escape') setOpen(false);
