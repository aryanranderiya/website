---
import FooterSocials from './FooterSocials';
import { SITE } from '@/constants/site';

const year = new Date().getFullYear();
const { timezone, location } = SITE;
---

<footer class="mt-auto pt-6 pb-32">
  <div class="page-container">
    <div class="relative flex items-center">
      <!-- left: clock + time -->
      <div class="flex items-center gap-2">
        <svg id="footer-clock" width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg">
          <circle cx="9" cy="9" r="9" fill="var(--text-ghost)"/>
          <line id="clock-hour"   x1="9" y1="9" x2="9" y2="5" stroke="var(--background)" stroke-width="2.4" stroke-linecap="round"/>
          <line id="clock-minute" x1="9" y1="9" x2="9" y2="2.5" stroke="var(--background)" stroke-width="1.6" stroke-linecap="round"/>
          <circle cx="9" cy="9" r="1.3" fill="var(--background)"/>
        </svg>
        <span id="footer-time" class="text-[12px] text-[var(--text-ghost)]"></span>
      </div>
      <!-- center: copyright -->
      <span class="absolute left-1/2 -translate-x-1/2 text-[12px] text-[var(--text-ghost)] whitespace-nowrap">
        © {year} Aryan Randeriya
      </span>
      <!-- right: socials -->
      <div class="ml-auto">
        <FooterSocials client:load />
      </div>
    </div>
  </div>
</footer>

<script define:vars={{ timezone }}>
  function updateClock() {
    const now = new Date();

    // Time display
    const timeEl = document.getElementById('footer-time');
    if (timeEl) {
      timeEl.textContent = now.toLocaleTimeString('en-US', {
        timeZone: timezone,
        hour: 'numeric',
        minute: '2-digit',
        hour12: true,
      });
    }

    // Clock hands — use local time in the target timezone
    const parts = Object.fromEntries(
      new Intl.DateTimeFormat('en-US', {
        timeZone: timezone,
        hour: 'numeric',
        minute: 'numeric',
        second: 'numeric',
        hour12: false,
      }).formatToParts(now).map(({ type, value }) => [type, Number(value)])
    );

    const hours = parts.hour % 12;
    const minutes = parts.minute;
    const seconds = parts.second;

    const hourAngle   = (hours + minutes / 60) * 30 - 90;
    const minuteAngle = (minutes + seconds / 60) * 6 - 90;

    const cx = 9, cy = 9;
    const toRad = (deg) => (deg * Math.PI) / 180;

    const hourHand   = document.getElementById('clock-hour');
    const minuteHand = document.getElementById('clock-minute');

    if (hourHand) {
      const len = 4;
      hourHand.setAttribute('x2', String(cx + len * Math.cos(toRad(hourAngle))));
      hourHand.setAttribute('y2', String(cy + len * Math.sin(toRad(hourAngle))));
    }
    if (minuteHand) {
      const len = 6.5;
      minuteHand.setAttribute('x2', String(cx + len * Math.cos(toRad(minuteAngle))));
      minuteHand.setAttribute('y2', String(cy + len * Math.sin(toRad(minuteAngle))));
    }
  }

  updateClock();
  setInterval(updateClock, 1000);
</script>
