---
import { SOCIAL_LINKS } from '@/constants/navigation';

const year = new Date().getFullYear();
---

<footer class="mt-auto">
  <div class="page-container" style="padding-top: 64px; padding-bottom: 32px; border-top: 1px solid var(--border); margin-top: 48px;">
    <div class="flex items-center justify-between">
      <span style="font-size: 12px; color: var(--text-ghost);">© {year} Aryan Randeriya</span>
      <div style="display: flex; align-items: center; gap: 16px;">
        {SOCIAL_LINKS.map(link => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={link.label}
            style="font-size: 12px; color: var(--text-muted); text-decoration: none; transition: opacity 0.15s ease;"
            onmouseover="this.style.opacity='0.6'"
            onmouseout="this.style.opacity='1'"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
