  <div class="page-container" style="padding-top: 64px; padding-bottom: 128px; margin-top: 48px;">
    <div class="flex items-center justify-between">
      <span style="font-size: 12px; color: var(--text-ghost);">© {year} Aryan Randeriya</span>
      <FooterSocials client:load />
    </div>
  </div>
</footer>
