+		const tick = () => {
+			if (cancelled) return;
+			i++;
+			if (i >= greetings.length) {
+				const overlay = overlayRef.current;
+				if (overlay) {
+					overlay.style.opacity = '0';
+					window.dispatchEvent(new CustomEvent('preloader:done'));
