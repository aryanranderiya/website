---
import { HugeiconsIcon, TextAlignLeftIcon } from '@icons';

interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  toc.length > 0 && (
    <nav id="toc" aria-label="Table of contents">
      <p class="flex items-center gap-[5px] text-[10px] font-medium tracking-[0.08em] uppercase text-[var(--text-ghost)] mb-[10px]">
        <HugeiconsIcon icon={TextAlignLeftIcon} size={11} color="var(--text-ghost)" />
        On this page
      </p>
      <ul class="list-none p-0 m-0 flex flex-col gap-px">
        {toc.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              class:list={[
                'toc-link block leading-[1.5] py-[3px] transition-colors duration-150 no-underline hover:text-[var(--text-secondary)]',
                h.depth === 3
                  ? 'pl-[10px] text-[11px] text-[var(--text-ghost)]'
                  : 'text-[11.5px] text-[var(--text-muted)]',
              ]}
              data-heading={h.slug}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<style>
  .toc-link.active {
    color: var(--text-primary);
  }
</style>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('#toc .toc-link');

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          links.forEach((l) => l.classList.remove('active'));
          const active = document.querySelector(`#toc .toc-link[data-heading="${id}"]`);
          if (active) active.classList.add('active');
        }
      }
    },
    { rootMargin: '0px 0px -70% 0px', threshold: 0 },
  );

  links.forEach((link) => {
    const id = link.getAttribute('data-heading');
    if (id) {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    }
  });
</script>
