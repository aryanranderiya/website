---
import { Clock01Icon, Folder03Icon, HugeiconsIcon, QuillWrite01Icon } from '@icons';
import type { IconProps } from '@theexperiencecompany/gaia-icons';
import type { ComponentType } from 'react';
import PreviewLink from '@/components/ui/PreviewLink';
import SocialsGrid from './SocialsGrid';

const links = [
	{ label: 'Work', href: '/projects', icon: Folder03Icon },
	{ label: 'Blog', href: '/blog', icon: QuillWrite01Icon },
	{ label: 'Now', href: '/now', icon: Clock01Icon },
] as { label: string; href: string; icon: ComponentType<IconProps> }[];
---

<section class="pt-4 pb-12 hero-waiting">
	<h1 class="text-2xl font-semibold text-[var(--text-primary)] m-0 mb-4 animate-fade-in" style="animation-delay:0.05s">
		Hey! Welcome to my digital world.
		<img
			src="/images/waving-hand.webp"
			alt="Waving hand"
			width="28"
			height="28"
			class="inline align-middle w-auto h-[0.9em] mb-[2px]"
		/>
	</h1>

	<p class="text-[14px] text-[var(--text-muted)] leading-[1.65] m-0 mb-3 max-w-2xl animate-fade-in" style="animation-delay:0.12s">
		My name is
		<img
			src="/avatar.webp"
			alt="Aryan Randeriya"
			width="28"
			height="28"
			class="inline align-middle rounded-full w-auto h-[1.4em] mb-0.5 ml-2"
			fetchpriority="high"
			loading="eager"
		/>{' '}
		Aryan Randeriya and I'm a Designer, Developer,
		<br />
		and the Founder & CEO of
		<PreviewLink
			client:visible
			href="https://experience.heygaia.io"
			logo="/images/experience-company-logo.svg"
			name="The Experience Company"
			logoClassName="logo-invert"
			rounded={false}
			preview={{
				image: '/images/theexperiencecompany.webp',
				favicon: '/images/experience-company-logo.svg',
				name: 'experience.heygaia.io',
				title: 'The Experience Company',
				description:
					'A studio improving the human experience — building products people actually love to use.',
			}}
		/>
		. The name comes from two things: our belief that our mission is to improve the human
		experience, and our deep care about the experience of every product we build.
	</p>

	<p class="text-[14px] text-[var(--text-muted)] leading-[1.65] m-0 mb-3 max-w-2xl animate-fade-in" style="animation-delay:0.19s">
		Currently building{' '}
		<PreviewLink
			client:visible
			href="https://heygaia.io"
			logo="/gaia-logo.webp"
			name="GAIA"
			preview={{
				favicon: '/gaia-logo.webp',
				name: 'heygaia.io',
				title: 'GAIA — your proactive personal AI',
				description:
					'A proactive personal AI assistant that acts before you even need to ask. Voice-first, calendar-aware, and built to feel like a teammate.',
			}}
		/>
		, a proactive personal AI assistant that acts before you even need to ask. The goal: every person
		in the world should have their own truly intelligent assistant.
	</p>

	<p class="text-[14px] text-[var(--text-muted)] leading-[1.65] m-0 mb-3 max-w-2xl animate-fade-in" style="animation-delay:0.22s">
		The fastest way to reach me is{' '}
		<PreviewLink
			client:visible
			href="mailto:aryan@heygaia.io"
			name="aryan@heygaia.io"
			preview={{
				favicon: '/gaia-logo.webp',
				name: 'Email',
				title: 'aryan@heygaia.io',
				description:
					'I respond to all my emails within reason — say hi, pitch an idea, or just ramble about a side project.',
			}}
		/>
		. I respond to all my emails within reason.
	</p>

	<p class="text-[14px] text-[var(--text-muted)] leading-[1.65] m-0 mb-3 max-w-2xl animate-fade-in" style="animation-delay:0.26s">
		I'm a tech nerd who's been tinkering with computers since a very young age.
		<br />
		Born in{' '}
		<img src="/images/flag-uk.webp" alt="UK" width="24" height="16" class="inline align-middle w-auto h-[1.3em] mb-[1px]" />
		the United Kingdom, based in{' '}
		<img
			src="/images/flag-india.webp"
			alt="India"
			width="24"
			height="16"
			class="inline align-middle w-auto h-[1.3em] mb-[1px]"
		/>
		India. I love building products; I'm a product guy but a developer and designer by heart. I
		love music (I have a{' '}
		<PreviewLink
			client:visible
			href="https://open.spotify.com/playlist/1kDa0wKgm0baT3550xsURH"
			logo="https://cdn.simpleicons.org/spotify/1DB954"
			name="Spotify playlist"
			preview={{
				favicon: 'https://cdn.simpleicons.org/spotify/1DB954',
				name: 'open.spotify.com',
				title: 'My all-time playlist',
				description:
					"2,000+ songs across moods and decades — what I actually listen to while shipping.",
			}}
		/>
		{' '}with 2000+ songs), movies, and food. I love tinkering around with code, shipping things, and
		exploring new ideas. Maybe that's just my ADHD lol
	</p>

	<p class="text-[14px] text-[var(--text-muted)] leading-[1.65] m-0 mb-7 max-w-2xl animate-fade-in" style="animation-delay:0.33s">
		Some things I want to explore in the future: Hardware, robotics, personal companions, smart
		wearables, and some low-level (hardware?) programming with stuff like Rust
	</p>

	<div class="flex gap-2 mb-6 flex-wrap animate-fade-in" style="animation-delay:0.33s">
		{links.map(({ label, href, icon }) => (
			<a
				href={href}
				class="text-[12px] text-[var(--text-secondary)] no-underline inline-flex items-center gap-[5px] bg-[var(--muted-bg)] rounded-[10px] px-3 py-[5px] font-medium transition-[filter] duration-150 hover:brightness-[0.96]"
			>
				<HugeiconsIcon icon={icon} size={12} color="currentColor" />
				{label}
			</a>
		))}
	</div>

	<div class="animate-fade-in" style="animation-delay:0.40s">
		<SocialsGrid client:idle />
	</div>
</section>

<style>
	/* Pause all hero animations until the preloader is done (matches original useAfterPreloader behaviour).
	   The script below removes this class — either immediately (repeat visits) or on preloader:done (first visit). */
	.hero-waiting .animate-fade-in {
		animation-play-state: paused;
	}
</style>

<script>
	(function () {
		const hero = document.querySelector('.hero-waiting') as HTMLElement | null;
		if (!hero) return;

		function start() {
			hero!.classList.remove('hero-waiting');
		}

		// If preloader was already shown in a previous session, start immediately
		try {
			if (sessionStorage.getItem('preloader_shown')) {
				start();
				return;
			}
		} catch {}

		// First visit — wait for the preloader to fire its done event
		window.addEventListener('preloader:done', start, { once: true });
		// Safety fallback: if event never fires (e.g. preloader removed), start after 2s
		setTimeout(start, 2000);
	})();
</script>
