		src="/images/flag-india.webp"
		alt="India"
		width="24"
		height="16"
		class="inline align-middle w-auto h-[1.3em] mb-[1px]"
	/>
	India. I love building products; I'm a product guy but a developer and designer
	by heart. I love music (I have a{" "}
	<PreviewLink
		client:visible
		href="https://open.spotify.com/playlist/1kDa0wKgm0baT3550xsURH"
		logo="https://cdn.simpleicons.org/spotify/1DB954"
		name="Spotify playlist"
		rounded={false}
		preview={spotifyOg ?? undefined}
	/>
	{" "}with 2000+ songs), movies, and food. I love tinkering around with code,
	shipping things, and exploring new ideas. Maybe that's just my ADHD lol
</p>

<p
	class="text-[14px] text-(--text-muted) leading-[1.65] m-0 mb-7 max-w-2xl animate-fade-in"
	style="animation-delay:0.33s"
>
	Some things I want to explore in the future: Hardware, robotics, personal
	companions, smart wearables, and some low-level (hardware?) programming with
	stuff like Rust
</p>

<div
	class="flex gap-2 flex-wrap animate-fade-in mb-7"
	style="animation-delay:0.33s"
>
	<ButtonLink
		href="/blog"
		label="View writings"
		icon="quill-write"
		trailingArrow
		size="sm"
		client:load
	/>
	<ButtonLink
		href="/projects"
		label="View projects"
		icon="folder"
		trailingArrow
		variant="secondary"
		size="sm"
		client:load
	/>
</div>

<style>
	/* Pause all hero animations until the preloader is done (matches original useAfterPreloader behaviour).
	   The script below removes this class — either immediately (repeat visits) or on preloader:done (first visit). */
	.hero-waiting .animate-fade-in {
		animation-play-state: paused;
	}
</style>

<script>
	(function () {
		const hero = document.querySelector(
			".hero-waiting",
		) as HTMLElement | null;
		if (!hero) return;

		function start() {
			hero!.classList.remove("hero-waiting");
		}

		// If preloader was already shown in a previous session, start immediately
		try {
			if (sessionStorage.getItem("preloader_shown")) {
				start();
				return;
			}
		} catch {}

		// First visit — wait for the preloader to fire its done event
		window.addEventListener("preloader:done", start, { once: true });
		// Safety fallback: if event never fires (e.g. preloader removed), start after 2s
		setTimeout(start, 2000);
	})();
</script>
