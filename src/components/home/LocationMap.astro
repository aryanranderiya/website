---
// Apple Maps embed for Ahmedabad, India
---

<div class="location-map-inner h-full flex flex-col">
  <div class="text-xs font-medium mb-3" style="color: var(--muted-foreground); letter-spacing: 0.05em; text-transform: uppercase;">
    Location
  </div>
  <div
    class="relative rounded-xl overflow-hidden flex-1"
    style="min-height: 140px;"
  >
    <iframe
      title="Ahmedabad, India location"
      src="https://maps.apple.com/?q=Ahmedabad,Gujarat,India&ll=23.0225,72.5714&z=12&t=m"
      width="100%"
      height="100%"
      style="border: 0; display: block; filter: grayscale(0.4);"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>

    <!-- Overlay gradient at bottom -->
    <div
      class="absolute bottom-0 left-0 right-0 h-16 pointer-events-none"
      style="background: linear-gradient(to top, var(--card), transparent);"
    ></div>

    <!-- Location badge -->
    <div
      class="absolute bottom-3 left-3 flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-medium"
      style="background: var(--card); backdrop-filter: blur(8px); border: 1px solid var(--border);"
    >
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="color: var(--foreground); flex-shrink: 0;">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
      <span style="color: var(--foreground);">Ahmedabad</span>
      <span class="w-1 h-1 rounded-full inline-block" style="background: var(--border);"></span>
      <span class="flex items-center gap-1" style="color: var(--muted-foreground);">
        <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse inline-block"></span>
        IST
      </span>
    </div>
  </div>
</div>
