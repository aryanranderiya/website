---
// Apple Maps embed for Ahmedabad, India
---

<div class="location-map-inner h-full flex flex-col">
  <div class="text-xs font-medium mb-3 text-[var(--muted-foreground)] tracking-[0.05em] uppercase">
    Location
  </div>
  <div class="relative rounded-xl overflow-hidden flex-1 min-h-[140px]">
    <iframe
      title="Ahmedabad, India location"
      src="https://maps.apple.com/?q=Ahmedabad,Gujarat,India&ll=23.0225,72.5714&z=12&t=m"
      width="100%"
      height="100%"
      class="block grayscale-[0.4] border-0"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>

    <!-- Overlay gradient at bottom -->
    <div
      class="absolute bottom-0 left-0 right-0 h-16 pointer-events-none bg-[linear-gradient(to_top,var(--card),transparent)]"
    ></div>

    <!-- Location badge -->
    <div
      class="absolute bottom-3 left-3 flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-medium bg-[var(--card)] backdrop-blur-[8px]"
    >
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-[var(--foreground)] shrink-0">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
      <span class="text-[var(--foreground)]">Ahmedabad</span>
      <span class="w-1 h-1 rounded-full inline-block bg-[var(--border)]"></span>
      <span class="flex items-center gap-1 text-[var(--muted-foreground)]">
        <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse inline-block"></span>
        IST
      </span>
    </div>
  </div>
</div>
