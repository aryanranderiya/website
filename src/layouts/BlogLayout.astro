---
import PageLayout from "./PageLayout.astro";
import TableOfContents from "@/components/blog/TableOfContents.astro";
import Giscus from "@/components/blog/Giscus.astro";
import { formatDate } from "@/lib/utils";
import { SITE } from "@/constants/site";
import { Calendar02Icon, Clock01Icon, HugeiconsIcon } from "@/components/icons";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  tags?: string[];
  category?: string;
  cover?: string;
  headings?: Heading[];
  readingTime?: number;
}

const {
  title,
  description,
  date,
  updated,
  tags = [],
  category,
  cover,
  headings = [],
  readingTime,
} = Astro.props;
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

const canonicalURL = new URL(Astro.url.pathname, SITE.url).toString();
const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: description,
  datePublished: date.toISOString(),
  ...(updated ? { dateModified: updated.toISOString() } : {}),
  author: {
    "@type": "Person",
    name: SITE.name,
    url: SITE.url,
  },
  publisher: {
    "@type": "Person",
    name: SITE.name,
    url: SITE.url,
  },
  ...(cover
    ? {
        image: cover.startsWith("http")
          ? cover
          : new URL(cover, SITE.url).toString(),
      }
    : {}),
  url: canonicalURL,
  inLanguage: "en-US",
  isPartOf: { "@type": "Blog", url: `${SITE.url}/blog` },
});

const breadcrumbJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: SITE.url },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: `${SITE.url}/blog`,
    },
    { "@type": "ListItem", position: 3, name: title, item: canonicalURL },
  ],
});
---

<PageLayout
  title={title}
  description={description}
  ogImage={cover}
  ogType="article"
  articleDate={date}
  articleModified={updated}
  fullWidth={true}
>
  <script is:inline type="application/ld+json" set:html={articleJsonLd} />
  <script is:inline type="application/ld+json" set:html={breadcrumbJsonLd} />
  <div class="blog-wrapper">
    <article class="blog-content" style="padding-bottom: 64px;">
      {
        cover && (
          <img
            src={cover}
            alt={title}
            class="w-full aspect-video object-cover rounded-2xl mb-10"
          />
        )
      }

      <!-- Header -->
      <header class="mb-10">
        <!-- Meta row: category chip + date + reading time -->
        <div class="flex flex-wrap items-center gap-2 mb-4 text-caption">
          {
            category && (
              <span
                class="px-2 py-0.5 rounded-full text-xs font-medium bg-[var(--muted-bg)]"
                style="color: var(--text-muted); letter-spacing: 0.04em; text-transform: uppercase; font-size: 10px;"
              >
                {category}
              </span>
            )
          }
          {category && <span style="color: var(--text-ghost);">·</span>}
          <span class="flex items-center gap-1" style="color: var(--text-ghost);">
            <Calendar02Icon width={12} height={12} />
            <time datetime={date.toISOString()}>{formatDate(date)}</time>
          </span>
          {
            readingTime && (
              <>
                <span style="color: var(--text-ghost);">·</span>
                <span class="flex items-center gap-1" style="color: var(--text-ghost);">
                  <Clock01Icon width={12} height={12} />
                  <span>{readingTime} min read</span>
                </span>
              </>
            )
          }
        </div>

        <h1 class="text-heading-1 mb-5">{title}</h1>

        {
          tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5">
              {tags.map((tag) => (
                <span
                  class="text-xs px-2.5 py-1 rounded-full bg-[var(--muted-bg)]"
                  style="color: var(--text-ghost);"
                >
                  {tag
                    .split(" ")
                    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
                    .join(" ")}
                </span>
              ))}
            </div>
          )
        }
      </header>

      <!-- Content -->
      <div class="prose">
        <slot />
      </div>

      <Giscus />
    </article>

    {
      tocHeadings.length > 1 && (
        <aside class="blog-toc-aside">
          <TableOfContents headings={headings} />
        </aside>
      )
    }
  </div>
</PageLayout>

<style>
  .blog-wrapper {
    display: flex;
    /* Align left edge with page-container so sidebar isn't encroached;
       TOC extends to the right naturally instead of centering the wider box */
    margin-left: max(0px, calc((100% - var(--prose-max-width)) / 2));
    padding: 0 var(--page-inset);
    gap: 56px;
    align-items: flex-start;
  }

  .blog-content {
    flex: 1;
    min-width: 0;
    max-width: var(--prose-max-width);
  }

  .blog-toc-aside {
    display: none;
    width: 176px;
    flex-shrink: 0;
    position: sticky;
    top: calc(var(--section-padding-top) + 24px);
  }

  @media (min-width: 1080px) {
    .blog-toc-aside {
      display: block;
    }
  }
</style>
