---
import BlogLinks from '@/components/blog/BlogLinks';
import Giscus from '@/components/blog/Giscus.astro';
import Lightbox from '@/components/ui/Lightbox.astro';
import TableOfContents from '@/components/ui/TableOfContents.astro';
import { SITE } from '@/constants/site';
import { formatDate } from '@/lib/utils';
import PageLayout from './PageLayout.astro';

interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	title: string;
	description: string;
	date: Date;
	updated?: Date;
	tags?: string[];
	category?: string;
	cover?: string;
	headings?: Heading[];
	readingTime?: number;
}

const {
	title,
	description,
	date,
	updated,
	tags = [],
	category,
	cover,
	headings = [],
	readingTime,
} = Astro.props;
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

const canonicalURL = new URL(Astro.url.pathname, SITE.url).toString();
const articleJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description: description,
	datePublished: date.toISOString(),
	...(updated ? { dateModified: updated.toISOString() } : {}),
	author: {
		'@type': 'Person',
		name: SITE.name,
		url: SITE.url,
	},
	publisher: {
		'@type': 'Person',
		name: SITE.name,
		url: SITE.url,
	},
	...(cover
		? {
				image: cover.startsWith('http') ? cover : new URL(cover, SITE.url).toString(),
			}
		: {}),
	url: canonicalURL,
	inLanguage: 'en-US',
	isPartOf: { '@type': 'Blog', url: `${SITE.url}/blog` },
});

const breadcrumbJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Blog',
			item: `${SITE.url}/blog`,
		},
		{ '@type': 'ListItem', position: 3, name: title, item: canonicalURL },
	],
});
---

<PageLayout
  title={title}
  description={description}
  ogImage={cover}
  ogType="article"
  articleDate={date}
  articleModified={updated}
  fullWidth={true}
  section="blog"
>
  <script is:inline type="application/ld+json" set:html={articleJsonLd} />
  <script is:inline type="application/ld+json" set:html={breadcrumbJsonLd} />

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const refs = document.querySelectorAll('.prose a[data-footnote-ref]');
      refs.forEach((ref) => {
        const id = (ref.getAttribute('href') || '').slice(1);
        const fnEl = id ? document.getElementById(id) : null;
        if (!fnEl) return;

        let tooltip = null;
        let hideTimer = null;

        ref.addEventListener('mouseenter', () => {
          clearTimeout(hideTimer);
          if (tooltip) return;

          // Clone footnote content, strip the backref arrow
          const clone = fnEl.cloneNode(true);
          clone.querySelectorAll('a[data-footnote-backref]').forEach((el) => el.remove());

          tooltip = document.createElement('div');
          tooltip.className = 'fn-tooltip';
          tooltip.innerHTML = clone.innerHTML;
          document.body.appendChild(tooltip);

          // Position above the ref (clamped to viewport)
          const r = ref.getBoundingClientRect();
          const tw = tooltip.offsetWidth;
          const th = tooltip.offsetHeight;
          let top = r.top + window.scrollY - th - 8;
          let left = r.left + window.scrollX + r.width / 2 - tw / 2;
          left = Math.max(8, Math.min(left, window.innerWidth - tw - 8));
          if (top < window.scrollY + 8) top = r.bottom + window.scrollY + 8;
          tooltip.style.top = top + 'px';
          tooltip.style.left = left + 'px';

          requestAnimationFrame(() => tooltip && tooltip.classList.add('fn-tooltip--visible'));
        });

        ref.addEventListener('mouseleave', () => {
          hideTimer = setTimeout(() => {
            if (tooltip) { tooltip.remove(); tooltip = null; }
          }, 80);
        });
      });
    });
  </script>

  <div
    class="flex ml-[max(0px,calc((100%-var(--content-max-width))/2))] gap-14 items-start px-4 min-[960px]:px-0"
  >
    <article class="flex-1 min-w-0 max-w-[var(--content-max-width)] pb-16">
      <!-- Breadcrumb -->
      <nav
        class="flex items-center gap-1.5 text-xs mb-8 text-[var(--text-ghost)]"
        aria-label="Breadcrumb"
      >
        <a
          href="/blog"
          class="text-[var(--text-ghost)] transition-colors hover:text-[var(--text-muted)]"
          >Blog</a
        >
        <span>/</span>
        <span class="truncate text-[var(--text-muted)]">{title}</span>
      </nav>

      {
        cover && (
          <img
            src={cover}
            alt={title}
            class="w-full object-contain rounded-xl mb-10"
          />
        )
      }

      <!-- Header -->
      <header class="mb-12">
        <h1 class="text-heading-1 mb-4">{title}</h1>
        <p class="text-body mb-5 text-[var(--text-muted)]">{description}</p>
        <div class="flex flex-wrap items-center text-[12px] text-[var(--text-ghost)] tracking-[-0.01em] gap-x-3 gap-y-1.5">
          {category && (
            <a
              href={`/blog?tag=${encodeURIComponent(category.toLowerCase())}`}
              class="no-underline! text-[var(--text-ghost)] hover:text-[var(--text-primary)] transition-colors duration-150"
            >
              {category.charAt(0).toUpperCase() + category.slice(1)}
            </a>
          )}
          <time datetime={date.toISOString()}>{formatDate(date)}</time>
          {readingTime && (<span>{readingTime} min read</span>)}
          {updated && (<span>Updated {formatDate(updated)}</span>)}
        </div>
        {
          tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-3">
              {tags.map((tag) => (
                <a
                  href={`/blog?tag=${encodeURIComponent(tag.toLowerCase())}`}
                  class="no-underline! text-[11px] px-2 py-[3px] rounded-full bg-[var(--muted-bg)] text-[var(--text-ghost)] hover:text-[var(--text-secondary)] hover:bg-[var(--muted-bg-strong,var(--muted-bg))] transition-colors duration-150"
                >
                  {tag.toLowerCase()}
                </a>
              ))}
            </div>
          )
        }
      </header>

      <!-- Content -->
      <div class="prose">
        <slot />
      </div>

      <Giscus />
    </article>

    <BlogLinks client:idle />

    <Lightbox target=".prose img:not(.blog-link-favicon), .prose figure img:not(.blog-link-favicon)" />

    <script is:inline>
      (function () {
        function setupProseImages() {
          document.querySelectorAll('.prose img').forEach(function (img) {
            if (img.classList.contains('blog-link-favicon')) return;
            if (img.closest('a')) return;
            if (img.parentNode.classList.contains('prose-img-wrap')) return;

            var wrap = document.createElement('div');
            wrap.className = 'prose-img-wrap';
            if (img.classList.contains('fit')) wrap.classList.add('fit');
            img.parentNode.insertBefore(wrap, img);
            wrap.appendChild(img);

            // Shimmer while image loads — give wrap a temporary height so
            // the shimmer is visible before the browser knows image dimensions
            if (!img.complete || img.naturalWidth === 0) {
              wrap.style.minHeight = '160px';
              var shimmer = document.createElement('div');
              shimmer.className = 'img-shimmer';
              wrap.appendChild(shimmer);
              var removeShimmer = function () {
                shimmer.remove();
                wrap.style.minHeight = '';
              };
              img.addEventListener('load', removeShimmer, { once: true });
              img.addEventListener('error', removeShimmer, { once: true });
            }

          });
        }

        setupProseImages();
        document.addEventListener('astro:after-swap', setupProseImages);
      })();
    </script>


    {
      tocHeadings.length > 1 && (
        <aside class="hidden min-[1080px]:block w-56 shrink-0 sticky top-[calc(var(--section-padding-top)+24px)]">
          <TableOfContents headings={headings} />
        </aside>
      )
    }
  </div>
</PageLayout>

<style is:global>
  /* Wrapper injected around every .prose img */
  .prose-img-wrap {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    line-height: 0;
    cursor: zoom-in;
  }

  /* Reset img styles — wrapper owns border + radius now */
  .prose .prose-img-wrap img {
    border: none;
    border-radius: 0;
    display: block;
  }

  /* Fit mode: wrapper shrinks to the picture's natural size so the
     border hugs the image instead of empty letterbox. The wrapper class
     is mirrored from the inner <img class="fit"> at wrap time. */
  .prose-img-wrap.fit {
    display: inline-block;
    max-width: 100%;
    vertical-align: top;
  }
  .prose figure:has(.prose-img-wrap.fit) {
    text-align: center;
  }

  /* Shimmer skeleton shown while image is loading */
  .prose-img-wrap .img-shimmer {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      110deg,
      var(--shimmer-base) 8%,
      var(--shimmer-sweep) 18%,
      var(--shimmer-base) 33%
    );
    background-size: 220% 100%;
    animation: prose-img-shimmer 1.4s linear infinite;
    pointer-events: none;
  }

  @keyframes prose-img-shimmer {
    from { background-position: 220% 0; }
    to   { background-position: -120% 0; }
  }

</style>
