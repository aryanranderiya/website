---
import PageLayout from './PageLayout.astro';
import TableOfContents from '@/components/blog/TableOfContents.astro';
import { formatDate } from '@/lib/utils';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  tags?: string[];
  category?: string;
  cover?: string;
  headings?: Heading[];
  readingTime?: number;
}

const { title, description, date, updated, tags = [], category, cover, headings = [], readingTime } = Astro.props;
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<PageLayout title={title} description={description} fullWidth={true}>
  <div class="blog-wrapper">
    <article class="blog-content" style="padding-bottom: 64px;">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-1.5 text-xs mb-8" style="color: var(--text-ghost);" aria-label="Breadcrumb">
        <a href="/blog" class="transition-colors hover:text-[var(--text-muted)]" style="color: var(--text-ghost);">Blog</a>
        <span>/</span>
        <span class="truncate" style="color: var(--text-muted);">{title}</span>
      </nav>

      {cover && (
        <img
          src={cover}
          alt={title}
          class="w-full aspect-video object-cover rounded-xl mb-10"
        />
      )}

      <!-- Header -->
      <header class="mb-12">
        {category && (
          <div class="text-label mb-3" style="color: var(--accent-blue)">
            {category}
          </div>
        )}
        <h1 class="text-heading-1 mb-4">{title}</h1>
        <p class="text-body mb-5" style="color: var(--text-muted);">{description}</p>
        <div class="flex items-center gap-3 text-caption">
          <time datetime={date.toISOString()}>{formatDate(date)}</time>
          {updated && (
            <>
              <span style="color: var(--text-ghost);">·</span>
              <span>Updated {formatDate(updated)}</span>
            </>
          )}
          {readingTime && (
            <>
              <span style="color: var(--text-ghost);">·</span>
              <span>{readingTime} min read</span>
            </>
          )}
        </div>
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mt-4">
            {tags.map(tag => (
              <span class="text-xs px-2.5 py-1 rounded-full bg-[var(--muted-bg)]" style="color: var(--text-ghost);">
                {tag.split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}
              </span>
            ))}
          </div>
        )}
      </header>

      <!-- Content -->
      <div class="prose">
        <slot />
      </div>
    </article>

    {tocHeadings.length > 1 && (
      <aside class="blog-toc-aside">
        <TableOfContents headings={headings} />
      </aside>
    )}
  </div>
</PageLayout>

<style>
  .blog-wrapper {
    display: flex;
    /* Align left edge with page-container so sidebar isn't encroached;
       TOC extends to the right naturally instead of centering the wider box */
    margin-left: max(0px, calc((100% - var(--prose-max-width)) / 2));
    padding: 0 var(--page-inset);
    gap: 56px;
    align-items: flex-start;
  }

  .blog-content {
    flex: 1;
    min-width: 0;
    max-width: var(--prose-max-width);
  }

  .blog-toc-aside {
    display: none;
    width: 176px;
    flex-shrink: 0;
    position: sticky;
    top: calc(var(--section-padding-top) + 24px);
  }

  @media (min-width: 1080px) {
    .blog-toc-aside {
      display: block;
    }
  }
</style>
