---
import { formatDate } from '@/lib/utils';
import { fetchOgMetadata } from '@/lib/fetchOgMetadata';
import PreviewLink from '@/components/ui/PreviewLink';
import PageLayout from './PageLayout.astro';

interface NowEntry {
	slug: string;
	date: Date;
	isLatest: boolean;
}

interface Props {
	date: Date;
	location?: string;
	entries: NowEntry[];
	currentSlug: string;
}

const { date, location, entries, currentSlug } = Astro.props;

const sivrsOg = await fetchOgMetadata('https://sive.rs/now3');
---

<PageLayout title="Now" description="What I'm focused on right now." fullWidth={true}>
  <div class="flex ml-[max(0px,calc((100%-var(--prose-max-width))/2))] px-[var(--page-inset)] gap-14 items-start">
    <article class="flex-1 min-w-0 max-w-[var(--prose-max-width)] pb-16">
      <header class="mb-10">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-1.5 text-xs mb-4 text-[var(--text-ghost)]" aria-label="Breadcrumb">
          <a href="/now" class="text-[var(--text-ghost)] transition-colors hover:text-[var(--text-muted)]">Now</a>
          <span>/</span>
          <span class="text-[var(--text-muted)]">{formatDate(date)}</span>
        </nav>
        <p class="text-sm">
          This is a{' '}
          <PreviewLink
            client:visible
            href="https://sive.rs/now3"
            name="/now page"
            preview={sivrsOg ?? undefined}
          />{' '}
          - what I'm focused on at this point in my life.
        </p>
      </header>

      <div class="prose prose-compact">
        <slot />
      </div>
    </article>

    {entries.length > 0 && (
      <aside class="hidden min-[1080px]:block w-44 shrink-0 sticky top-[calc(var(--section-padding-top)+24px)]">
        <nav>
          <p class="text-[10px] font-medium tracking-[0.08em] uppercase text-[var(--text-ghost)] mb-2.5">
            Past updates
          </p>
          <ul class="list-none p-0 m-0 flex flex-col gap-px">
            {entries.map(entry => (
              <li>
                <a
                  href={entry.isLatest ? '/now' : `/now/${entry.slug}`}
                  class:list={[
                    'block text-[11.5px] leading-snug py-[3px] transition-colors duration-150 no-underline overflow-hidden text-ellipsis whitespace-nowrap',
                    entry.slug === currentSlug
                      ? 'text-[var(--text-primary)]'
                      : 'text-[var(--text-muted)] hover:text-[var(--text-secondary)]',
                  ]}
                >
                  {formatDate(entry.date)}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    )}
  </div>
</PageLayout>
