---
import Footer from '@/components/layout/Footer.astro';
import Sidebar from '@/components/layout/Sidebar';
import Layout from './Layout.astro';

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	ogType?: 'website' | 'article';
	canonical?: string;
	noindex?: boolean;
	fullWidth?: boolean;
	articleDate?: Date;
	articleModified?: Date;
	section?: string;
}

const {
	fullWidth = false,
	ogType = 'website',
	ogImage,
	articleDate,
	articleModified,
	section,
	...layoutProps
} = Astro.props;
---

<Layout
	{...layoutProps}
	ogImage={ogImage}
	ogType={ogType}
	articleDate={articleDate}
	articleModified={articleModified}
	section={section}
>
	{/* Explicit `transition:persist="sidebar"` name — auto-generated keys are
	    position-based and shift when adjacent islands change between pages
	    (e.g. /projects → /projects/[slug]), which would silently remount the
	    sidebar and re-trigger its Framer Motion entrance animation.
	    `transition:persist-props` freezes props so React doesn't re-render
	    when Astro hands new pathname/section in from the next page. */}
	<Sidebar
		pathname={Astro.url.pathname}
		section={section}
		client:load
		transition:persist="sidebar"
		transition:persist-props
	/>
	<main id="page-content" class="flex-1 pt-[72px] min-[960px]:pt-[60px]">
		{fullWidth ? (
			<slot />
		) : (
			<div class="page-container">
				<slot />
			</div>
		)}
	</main>
	<Footer />
</Layout>
