---
import { ViewTransitions } from 'astro:transitions';
import { getCollection } from 'astro:content';
import { SITE, SEO } from '@/constants/site';
import '@/styles/global.css';
import CommandK from '@/components/layout/CommandK';
import AgentationOverlay from '@/components/layout/AgentationOverlay';
import BlurStack from '@/components/ui/blur-stack';
import Preloader from '@/components/layout/Preloader';
import AIChat from '@/components/ui/AIChat';
import { buildAIPrompt } from '@/lib/build-ai-prompt';
import { experience, education, certifications } from '@/data/experience';
import { pastWork } from '@/data/freelance';
import { PetLauncher } from '@/components/ui/PetLauncher';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
  class?: string;
}

const {
  title,
  description = SITE.description,
  ogImage = '/og-image.jpg',
  canonical = Astro.url.pathname,
  noindex = false,
  class: className,
} = Astro.props;

const metaTitle = title ? `${title} — ${SITE.name}` : SEO.defaultTitle;
const canonicalURL = new URL(canonical, Astro.site ?? Astro.url.origin);
const ogImageURL = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site ?? Astro.url.origin).toString();

const [projects, blogPosts] = await Promise.all([
  getCollection('projects'),
  getCollection('blog'),
]);
const aiSystemPrompt = buildAIPrompt({ projects, blogPosts, experience, education, certifications, pastWork, site: SITE });
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary -->
    <title>{metaTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.name} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow" />}

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL.toString()} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.toString()} />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={`@${SITE.twitter}`} />
    <meta name="twitter:title" content={metaTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Theme -->
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0a0a0a" />

    <!-- Preconnects / prefetches for third-party origins -->
    <link rel="preconnect" href="https://api.mapbox.com" crossorigin />
    <link rel="preconnect" href="https://events.mapbox.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="preconnect" href="https://cdn.simpleicons.org" crossorigin />
    <link rel="dns-prefetch" href="https://api.github.com" />
    <link rel="dns-prefetch" href="https://github-contributions-api.jogruber.de" />
    <link rel="dns-prefetch" href="https://open.spotify.com" />

    <!-- View Transitions -->
    <ViewTransitions />

    <!-- Theme init — light by default, dark only if explicitly stored -->
    <script is:inline>
      function applyTheme() {
        var theme = localStorage.getItem('theme');
        var root = document.documentElement;
        // Reset dark class first
        root.classList.remove('dark');
        if (theme === 'dark') {
          root.classList.add('dark');
        } else if (theme === 'random') {
          var hue = parseInt(localStorage.getItem('randomHue') || '200', 10);
          var sat = parseInt(localStorage.getItem('randomSat') || '38', 10);
          var l = Math.max(88, Math.round(96 - (sat - 25) * 0.23));
          var card_s = Math.round(sat * 0.7);
          var card_l = Math.min(l + 2, 98);
          root.style.setProperty('--background',          'hsl(' + hue + ', ' + sat + '%, ' + l + '%)');
          root.style.setProperty('--foreground',          'hsl(' + hue + ', 22%, 11%)');
          root.style.setProperty('--card',                'hsl(' + hue + ', ' + card_s + '%, ' + card_l + '%)');
          root.style.setProperty('--card-foreground',     'hsl(' + hue + ', 22%, 11%)');
          root.style.setProperty('--popover',             'hsl(' + hue + ', ' + card_s + '%, ' + card_l + '%)');
          root.style.setProperty('--popover-foreground',  'hsl(' + hue + ', 22%, 11%)');
          root.style.setProperty('--primary',             'hsl(' + hue + ', 22%, 11%)');
          root.style.setProperty('--primary-foreground',  'hsl(' + hue + ', ' + sat + '%, ' + l + '%)');
          root.style.setProperty('--glass-bg',            'hsla(' + hue + ', ' + sat + '%, ' + l + '%, 0.85)');
          root.style.setProperty('--accent-blue',         'hsl(' + hue + ', 72%, 52%)');
        }
        // Restore typography (helvetica is the CSS default — skip it)
        var typography = localStorage.getItem('typography');
        if (typography && typography !== 'helvetica') {
          var fontMap = {
            inter:     "'Inter var', Inter, sans-serif",
            georgia:   "Georgia, 'Times New Roman', serif",
            palatino:  "'Palatino Linotype', Palatino, 'Book Antiqua', serif",
            mono:      "ui-monospace, 'Courier New', monospace",
            pixel:     "'VT323', monospace",
            impact:    "Impact, 'Arial Narrow', sans-serif",
            comic:     "'Comic Sans MS', 'Chalkboard SE', cursive"
          };
          var family = fontMap[typography];
          if (family) {
            root.style.setProperty('font-family', family);
            if (typography === 'pixel' && !document.getElementById('pixel-font-link')) {
              var link = document.createElement('link');
              link.id = 'pixel-font-link';
              link.rel = 'stylesheet';
              link.href = 'https://fonts.googleapis.com/css2?family=VT323&display=swap';
              document.head.appendChild(link);
            }
          }
        }
      }
      applyTheme();
      // Re-apply after each View Transition swap so dark class persists across navigation
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:dark:bg-zinc-900 focus:rounded-lg focus:shadow-lg">
      Skip to content
    </a>

    <div id="main-content" transition:animate="fade" class:list={['min-h-screen flex flex-col', className]}>
      <slot />
    </div>
    <Preloader client:load />
    <BlurStack client:only="react" className="fixed bottom-0 left-0 right-0 h-32 z-10 pointer-events-none" />
    <CommandK client:only="react" />
    <AIChat client:only="react" systemPrompt={aiSystemPrompt} />
    <script>import '@/bones/registry'</script>
    <AgentationOverlay client:only="react" />
    <PetLauncher client:only="react" />
  </body>
</html>
