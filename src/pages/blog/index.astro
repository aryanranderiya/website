---
import PageLayout from '@/layouts/PageLayout.astro';
import BlogList from '@/components/blog/BlogList';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map(p => ({
    slug: p.slug,
    title: p.data.title,
    date: p.data.date.toISOString(),
    featured: p.data.featured ?? false,
  }));
---

<PageLayout title="Blog" description="Writing about engineering, design, and building things.">
  <div class="mb-10">
    <div class="section-header">Writing</div>
    <h1 class="text-heading-1">Blog</h1>
  </div>

  <BlogList posts={posts} client:load />
</PageLayout>
