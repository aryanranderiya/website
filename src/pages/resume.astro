---
import PageLayout from '@/layouts/PageLayout.astro';
import ExperienceList from '@/components/resume/ExperienceList';
import GithubGraph from '@/components/home/GithubGraph';
import { education, certifications } from '@/data/experience';
import { buttonVariants } from '@/components/ui/raised-button';

const skillCategories = [
  {
    label: 'Languages',
    items: [
      { name: 'TypeScript',  slug: 'typescript', icon: 'typescript-original' },
      { name: 'JavaScript',  slug: 'javascript', icon: 'javascript-original' },
      { name: 'Python',      slug: 'python',     icon: 'python-original' },
      { name: 'Java',        slug: 'java',       icon: 'java-original' },
      { name: 'Kotlin',      slug: 'kotlin',     icon: 'kotlin-original' },
      { name: 'Go',          slug: 'go',         icon: 'go-original' },
      { name: 'C',           slug: 'c',          icon: 'c-original' },
      { name: 'C++',         slug: 'cplusplus',  icon: 'cplusplus-original' },
      { name: 'PHP',         slug: 'php',        icon: 'php-original' },
    ],
  },
  {
    label: 'Frontend',
    items: [
      { name: 'React',         slug: 'react',        icon: 'react-original' },
      { name: 'React Native',  slug: 'react',        icon: 'react-original' },
      { name: 'Next.js',       slug: 'nextjs',       icon: 'nextjs-original' },
      { name: 'Astro',         slug: 'astro',        icon: 'astro-original' },
      { name: 'TailwindCSS',   slug: 'tailwindcss',  icon: 'tailwindcss-original' },
      { name: 'HTML',          slug: 'html5',        icon: 'html5-original' },
      { name: 'CSS',           slug: 'css3',         icon: 'css3-original' },
      { name: 'Vite',          slug: 'vitejs',       icon: 'vitejs-original' },
    ],
  },
  {
    label: 'Backend',
    items: [
      { name: 'FastAPI',     slug: 'fastapi',    icon: 'fastapi-original' },
      { name: 'Node.js',     slug: 'nodejs',     icon: 'nodejs-original' },
      { name: 'Express',     slug: 'express',    icon: 'express-original' },
      { name: 'Flask',       slug: 'flask',      icon: 'flask-original' },
      { name: 'PostgreSQL',  slug: 'postgresql', icon: 'postgresql-original' },
      { name: 'MongoDB',     slug: 'mongodb',    icon: 'mongodb-original' },
      { name: 'Redis',       slug: 'redis',      icon: 'redis-original' },
      { name: 'Firebase',    slug: 'firebase',   icon: 'firebase-original' },
      { name: 'MySQL',       slug: 'mysql',      icon: 'mysql-original' },
      { name: 'SQLite',      slug: 'sqlite',     icon: 'sqlite-original' },
      { name: 'Supabase',    slug: 'supabase',   icon: 'supabase-original' },
    ],
  },
  {
    label: 'Tools',
    items: [
      { name: 'Figma',          slug: 'figma',          icon: 'figma-original' },
      { name: 'Git',            slug: 'git',            icon: 'git-original' },
      { name: 'Docker',         slug: 'docker',         icon: 'docker-original' },
      { name: 'Postman',        slug: 'postman',        icon: 'postman-original' },
      { name: 'Linux',          slug: 'linux',          icon: 'linux-original' },
      { name: 'Android Studio', slug: 'androidstudio',  icon: 'androidstudio-original' },
      { name: 'VSCode',         slug: 'vscode',         icon: 'vscode-original' },
    ],
  },
];

const DEVICON_BASE = 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons';
---

<PageLayout
  title="Resume"
  description="Aryan Randeriya — Developer and designer with a focus on full-stack web and mobile development."
>
  <div class="resume-content">

    <!-- ── Header ───────────────────────────────────────────────── -->
    <div class="resume-header">
      <p class="section-header" style="margin-bottom: 20px;">Resume</p>

      <h1 class="text-heading-1" style="letter-spacing: -0.03em; margin-bottom: 6px;">
        Aryan Randeriya
      </h1>

      <p style="font-size: 13px; color: var(--text-muted); margin-bottom: 10px;">
        Developer · Designer · Builder
      </p>

      <div class="contact-links">
        <a href="mailto:hey@aryanranderiya.com" class="contact-link">
          hey@aryanranderiya.com
        </a>
        <span class="contact-sep">·</span>
        <a href="https://github.com/aryanranderiya" target="_blank" rel="noopener" class="contact-link">
          github.com/aryanranderiya
        </a>
        <span class="contact-sep">·</span>
        <span style="font-size: 12px; color: var(--text-ghost);">Ahmedabad, India</span>
      </div>

      <div style="margin-top: 20px;">
        <a
          href="/resume.pdf"
          download
          class={buttonVariants({ variant: 'default', size: 'sm' })}
          style="text-decoration: none; gap: 6px;"
        >
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
          </svg>
          Download PDF
        </a>
      </div>

    </div>

    <!-- ── Experience ────────────────────────────────────────────── -->
    <section class="resume-section">
      <p class="section-header">Experience</p>
      <ExperienceList client:load />
    </section>

    <!-- ── Education ─────────────────────────────────────────────── -->
    <section class="resume-section">
      <p class="section-header">Education</p>
      <div class="education-list">
        {education.map((edu, i) => (
          <div
            class="education-item"
            style={i === education.length - 1 ? 'border-bottom: none;' : ''}
          >
            <div class="edu-logo-wrap">
              <img
                src={edu.logo}
                alt={edu.institution}
                width="28"
                height="28"
                style="width:28px;height:28px;border-radius:6px;object-fit:contain;"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
              />
              <div
                class="edu-logo-fallback"
                style="display:none;width:28px;height:28px;border-radius:6px;background:var(--muted-bg);align-items:center;justify-content:center;font-size:10px;font-weight:600;color:var(--text-muted);"
              >
                {edu.shortName.charAt(0)}
              </div>
            </div>
            <div class="edu-body">
              <div style="display:flex;align-items:baseline;gap:8px;flex-wrap:wrap;">
                <span style="font-size:13px;font-weight:600;color:var(--text-secondary);letter-spacing:-0.01em;">
                  {edu.shortName}
                </span>
                <span style="font-size:12px;color:var(--text-muted);">
                  {edu.degree} · {edu.field}
                </span>
                <span style="font-size:11px;color:var(--text-ghost);margin-left:auto;white-space:nowrap;">
                  {edu.startYear} — {edu.endYear}
                </span>
              </div>
              <div style="font-size:11px;color:var(--text-ghost);margin-top:3px;">
                {edu.institution} · {edu.location}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── Skills ─────────────────────────────────────────────────── -->
    <section class="resume-section">
      <p class="section-header">Skills</p>
      <div class="skills-grid">
        {skillCategories.map((cat) => (
          <div class="skill-category">
            <div class="skill-category-label">{cat.label}</div>
            <div class="skill-items">
              {cat.items.map((item) => (
                <div class="skill-item">
                  {item.slug && item.icon ? (
                    <img
                      src={`${DEVICON_BASE}/${item.slug}/${item.icon}.svg`}
                      alt={item.name}
                      width="18"
                      height="18"
                      style="width:18px;height:18px;opacity:0.7;flex-shrink:0;"
                      onerror="this.style.display='none';"
                    />
                  ) : (
                    <span style="width:18px;height:18px;display:inline-flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--text-ghost);flex-shrink:0;">✦</span>
                  )}
                  <span class="skill-name">{item.name}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── GitHub Graph ───────────────────────────────────────────── -->
    <section class="resume-section">
      <GithubGraph client:load />
    </section>

  </div>
</PageLayout>

<style>
  .resume-content {
    padding: 0 0 64px;
  }

  /* Header */
  .resume-header {
    margin-bottom: 40px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    font-size: 12px;
  }

  .contact-link {
    font-size: 12px;
    color: var(--text-ghost);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .contact-link:hover {
    color: var(--text-secondary);
  }

  .contact-sep {
    color: var(--text-ghost);
    font-size: 12px;
  }

  /* Section */
  .resume-section {
    margin-bottom: 36px;
  }

  /* Education */
  .education-list {
    display: flex;
    flex-direction: column;
  }

  .education-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
  }

  .edu-logo-wrap {
    padding-top: 1px;
    flex-shrink: 0;
  }

  .edu-body {
    flex: 1;
    min-width: 0;
  }

  /* Skills */
  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .skill-category {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: 12px;
    align-items: start;
  }

  .skill-category-label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-ghost);
    padding-top: 2px;
  }

  .skill-items {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
  }

  .skill-item {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .skill-name {
    font-size: 12px;
    color: var(--text-secondary);
    font-weight: 400;
  }

  @media print {
    header, footer, nav { display: none !important; }
    body { background: white !important; color: black !important; }
  }
</style>
