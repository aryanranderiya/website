---
import { getCollection } from 'astro:content';
import BlogPreview from '@/components/home/BlogPreview';
import FeaturedProjects from '@/components/home/FeaturedProjects';
import Hero from '@/components/home/Hero.astro';
import MapWidget from '@/components/home/MapWidget';
import Signature from '@/components/home/Signature';
import SocialsGrid from '@/components/home/SocialsGrid';
import SpotifyWidget from '@/components/home/SpotifyWidget';
import ExperienceList from '@/components/resume/ExperienceList.astro';
import PageLayout from '@/layouts/PageLayout.astro';
import { mapProject, sortProjects } from '@/utils/projects';

// Fetch and sort blog posts by date descending (exclude drafts)
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort(
	(a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Fetch projects for FeaturedProjects component
const allProjectEntries = await getCollection('projects');
const allProjects = sortProjects(allProjectEntries).map(mapProject);
---

<PageLayout
  title="Home"
  description="Founder, designer, and developer. Currently building GAIA, an AI companion."
>
  <!-- Hero -->
  <Hero />

  <!-- Spotify + Map -->
  <section class="pb-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <SpotifyWidget client:visible />
      <MapWidget client:visible />
    </div>
  </section>

  <!-- Socials -->
  <div class="pb-8">
    <SocialsGrid client:idle />
  </div>

  <!-- <div class="mt-8"> -->
    <!-- <ExperienceList featuredOnly compact /> -->
  <!-- </div> -->

  <!-- <FeaturedProjects projects={allProjects} client:visible /> -->

  <!-- <section class="pb-12">
    <Toolbox client:visible />
  </section> -->

  <BlogPreview posts={posts} client:visible />

  <Signature client:visible />
</PageLayout>
