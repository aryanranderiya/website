---
import PageLayout from '@/layouts/PageLayout.astro';
import ButtonLink from '@/components/ui/ButtonLink';
import FreelanceWork from '@/components/freelance/FreelanceWork.tsx';

const services = [
  {
    title: 'Web Development',
    description: 'React, Next.js, Astro. Landing pages to complex SaaS.',
  },
  {
    title: 'Mobile Development',
    description: 'React Native & Expo. iOS and Android.',
  },
  {
    title: 'UI/UX Design',
    description: 'Figma to code. I design and build — no handoff overhead.',
  },
  {
    title: 'Backend & APIs',
    description: 'FastAPI, Node.js, PostgreSQL. Scalable and clean.',
  },
];

const process = [
  {
    step: '01',
    title: 'Discovery',
    description: 'Understand the product, users, and constraints.',
  },
  {
    step: '02',
    title: 'Design & Build',
    description: 'Design in Figma, build in code. Parallel, not sequential.',
  },
  {
    step: '03',
    title: 'Ship & Iterate',
    description: 'Deploy fast, gather feedback, iterate. Done means done.',
  },
];
---

<PageLayout title="Freelance" description="Freelance web and mobile development services.">
  <div class="pb-16">

    <!-- Hero -->
    <section class="pb-10">
      <div class="section-header">FREELANCE</div>
      <div class="text-[11px] text-[var(--text-ghost)] mb-3">
        Available for work
      </div>
      <h1 class="text-heading-1 mb-4">
        Building products<br/>people actually use.
      </h1>
      <p class="text-sm text-[var(--text-muted)] max-w-[28rem] leading-relaxed mb-5">
        I work with founders and teams to design and ship digital products. Fast, clean, no bloat.
      </p>
      <ButtonLink
        href="mailto:hey@aryanranderiya.com"
        label="Get in touch →"
        variant="accent"
        size="sm"
        client:load
      />
    </section>

    <!-- What I Do -->
    <section class="py-10">
      <div class="section-header">WHAT I DO</div>
      <div>
        {services.map((service, i) => (
          <div class:list={['py-3', i < services.length - 1 && 'border-b border-[var(--border)]']}>
            <span class="text-sm font-semibold text-[var(--text-primary)]">
              {service.title}
            </span>
            <span class="text-xs text-[var(--text-muted)]"> — {service.description}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Selected Work -->
    <section class="py-10">
      <div class="section-header">SELECTED WORK</div>
      <FreelanceWork client:load />
    </section>

    <!-- Process -->
    <section class="py-10">
      <div class="section-header">PROCESS</div>
      <div class="flex flex-col gap-6">
        {process.map(item => (
          <div class="flex gap-5 items-start">
            <span class="text-[11px] font-semibold text-[var(--text-ghost)] tracking-[0.05em] min-w-[20px] pt-px">
              {item.step}
            </span>
            <div>
              <div class="text-sm font-semibold text-[var(--text-primary)] mb-0.5">
                {item.title}
              </div>
              <div class="text-xs text-[var(--text-muted)] leading-relaxed">
                {item.description}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>
</PageLayout>
