---
import { getCollection } from 'astro:content';
import AgentConvosList from '@/components/agent-convos/AgentConvosList';
import PageLayout from '@/layouts/PageLayout.astro';

const allConvos = await getCollection('agent-convos');
const convos = allConvos
	.sort((a, b) => {
		// Featured first, then by date
		if (a.data.featured && !b.data.featured) return -1;
		if (!a.data.featured && b.data.featured) return 1;
		return b.data.date.valueOf() - a.data.date.valueOf();
	})
	.map((c) => ({
		slug: c.slug,
		title: c.data.title,
		description: c.data.description,
		date: c.data.date.toISOString(),
		platform: c.data.platform,
		model: c.data.model,
		harness: c.data.harness,
		featured: c.data.featured,
		tokens: c.data.tokens,
		tokenCount: c.data.tokenCount,
		messageCount: c.data.messageCount,
		duration: c.data.duration,
		agentCount: c.data.agentCount,
		agents: c.data.agents,
	}));
---

<PageLayout
  title="Agent Conversations"
  description="A curated collection of technically impressive AI-assisted coding sessions: infrastructure automation, multi-agent orchestration, browser-driven debugging, and more."
>
  <div class="pb-16">
    <header class="mb-10">
      <h1 class="text-heading-1 mb-4">Agent Conversations</h1>
      <p class="text-body mb-3 max-w-[560px]">
        A curated selection of real conversations with AI coding agents like
        Claude Code, OpenCode, and Codex CLI. Not every session makes this list.
        These are the ones where i've felt like it's genuinely done something
        impressive or extremely long running tasks. LLM's are truly powerful with
        the proper harness, environment and tools around it.
      </p>
      <p class="text-caption max-w-[560px]">
        Each entry is a condensed, human-readable retelling of the session.
        Sensitive details (credentials, internal URLs, proprietary logic) are
        redacted. The focus is on the technical approach and what made it work.
      </p>
    </header>

    <AgentConvosList convos={convos} client:visible />
  </div>
</PageLayout>
