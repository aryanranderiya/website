---
import PageLayout from '@/layouts/PageLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { formatDate } from '@/lib/utils';
import { HugeiconsIcon, Calendar03Icon, Database01Icon, BubbleChatIcon, Clock01Icon, File01Icon, ArrowLeft01Icon } from '@icons';

export async function getStaticPaths() {
  const convos = await getCollection('agent-convos');
  return convos.map(convo => ({
    params: { slug: convo.slug },
    props: { convo },
  }));
}

interface Props {
  convo: CollectionEntry<'agent-convos'>;
}

const { convo } = Astro.props;
const { Content } = await convo.render();

const platformLabels: Record<string, string> = {
  'claude-code': 'Claude Code',
  opencode: 'OpenCode',
  codex: 'Codex CLI',
};

const platformIcons: Record<string, string> = {
  'claude-code': 'https://www.google.com/s2/favicons?domain=claude.ai&sz=32',
  opencode: 'https://www.google.com/s2/favicons?domain=opencode.ai&sz=32',
  codex: 'https://www.google.com/s2/favicons?domain=openai.com&sz=32',
};

function formatTokensExact(tokenCount?: number, tokens?: string): string | null {
  if (tokenCount) {
    if (tokenCount >= 1_000_000) return `${(tokenCount / 1_000_000).toFixed(1)}M`;
    if (tokenCount >= 1_000) return `${(tokenCount / 1_000).toFixed(0)}K`;
    return tokenCount.toLocaleString();
  }
  if (tokens) {
    return tokens
      .replace(/~/g, '')
      .replace(/\s+(session|across\s+sessions?|across\s+\d+\s+sessions?).*/i, '')
      .replace(/MB/gi, 'M')
      .trim() || null;
  }
  return null;
}

const tokensDisplay = formatTokensExact(convo.data.tokenCount, convo.data.tokens);
---

<PageLayout
  title={convo.data.title}
  description={convo.data.description}
  ogType="article"
  articleDate={convo.data.date}
>
  <article style="padding-bottom: 64px;">

    {/* Breadcrumb */}
    <nav class="flex items-center gap-1.5 text-xs mb-8" style="color: var(--text-ghost);" aria-label="Breadcrumb">
      <a href="/agent-convos" class="transition-colors hover:text-[var(--text-muted)]" style="color: var(--text-ghost);">Agent Conversations</a>
      <span>/</span>
      <span class="truncate" style="color: var(--text-muted);">{convo.data.title}</span>
    </nav>

    {/* Header */}
    <header class="mb-10">
      <h1 class="text-heading-1 mb-4">{convo.data.title}</h1>
      <p class="text-body mb-6" style="color: var(--text-muted);">{convo.data.description}</p>

      {/* Meta chips */}
      <div class="flex flex-wrap gap-2 mb-6">

        <span class="inline-flex items-center gap-1.5 rounded-full bg-[var(--muted-bg)] px-2.5 py-1" style="font-size: 11px; color: var(--text-secondary);">
          <HugeiconsIcon icon={Calendar03Icon} size={12} color="var(--text-ghost)" />
          <time datetime={convo.data.date.toISOString()}>{formatDate(convo.data.date)}</time>
        </span>

        <span class="inline-flex items-center gap-1.5 rounded-full bg-[var(--muted-bg)] px-2.5 py-1" style="font-size: 11px; color: var(--text-secondary);">
          <img
            src={platformIcons[convo.data.platform]}
            alt={platformLabels[convo.data.platform] ?? convo.data.platform}
            width="13"
            height="13"
            style="border-radius: 3px; opacity: 0.7; display: block; flex-shrink: 0;"
          />
          {platformLabels[convo.data.platform] ?? convo.data.platform}
          <span style="opacity: 0.3; margin: 0 1px;">/</span>
          <span style="font-family: var(--font-mono); font-size: 10px; color: var(--text-ghost);">{convo.data.model}</span>
        </span>

        {tokensDisplay && (
          <span class="inline-flex items-center gap-1.5 rounded-full bg-[var(--muted-bg)] px-2.5 py-1" style="font-size: 11px; color: var(--text-secondary);">
            <HugeiconsIcon icon={Database01Icon} size={12} color="var(--text-ghost)" />
            {tokensDisplay} tokens
          </span>
        )}

        {convo.data.messageCount > 0 && (
          <span class="inline-flex items-center gap-1.5 rounded-full bg-[var(--muted-bg)] px-2.5 py-1" style="font-size: 11px; color: var(--text-secondary);">
            <HugeiconsIcon icon={BubbleChatIcon} size={12} color="var(--text-ghost)" />
            {convo.data.messageCount} messages
          </span>
        )}

        {convo.data.duration && (
          <span class="inline-flex items-center gap-1.5 rounded-full bg-[var(--muted-bg)] px-2.5 py-1" style="font-size: 11px; color: var(--text-secondary);">
            <HugeiconsIcon icon={Clock01Icon} size={12} color="var(--text-ghost)" />
            {convo.data.duration}
          </span>
        )}

        {convo.data.filesChanged > 0 && (
          <span class="inline-flex items-center gap-1.5 rounded-full bg-[var(--muted-bg)] px-2.5 py-1" style="font-size: 11px; color: var(--text-secondary);">
            <HugeiconsIcon icon={File01Icon} size={12} color="var(--text-ghost)" />
            {convo.data.filesChanged} files
          </span>
        )}

      </div>

      {/* Agent names */}
      {convo.data.agents.length > 0 && (
        <div class="mb-4">
          <div class="flex flex-wrap gap-1">
            {convo.data.agents.map((agent: string) => (
              <span class="rounded-full bg-[var(--muted-bg)] px-2 py-0.5" style="font-size: 10px; color: var(--text-muted); font-family: var(--font-mono);">
                {agent}
              </span>
            ))}
          </div>
        </div>
      )}

    </header>

    {/* Content */}
    <div class="prose">
      <Content />
    </div>

    {/* Footer */}
    <div class="mt-16 pt-10" style="border-top: 1px solid var(--border);">
      <a
        href="/agent-convos"
        class="inline-flex items-center gap-2 transition-opacity hover:opacity-60"
        style="font-size: 13px; color: var(--text-muted);"
      >
        <HugeiconsIcon icon={ArrowLeft01Icon} size={14} color="currentColor" />
        All Conversations
      </a>
    </div>
  </article>
</PageLayout>
