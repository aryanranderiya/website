---
import { getCollection } from 'astro:content';
import MoviesGrid from '@/components/movies/MoviesGrid';
import PageLayout from '@/layouts/PageLayout.astro';

const movieEntries = await getCollection('movies');
const movies = movieEntries.map((entry) => ({
	slug: entry.slug,
	title: entry.data.title,
	year: entry.data.year,
	cover: entry.data.cover,
	imdbId: entry.data.imdbId,
	myRating: entry.data.myRating,
	status: entry.data.status,
	review: entry.data.review,
	thoughts: entry.data.thoughts,
	favCharacters: entry.data.favCharacters,
	genre: entry.data.genre,
	director: entry.data.director,
	dateWatched: entry.data.dateWatched?.toISOString(),
	featured: entry.data.featured,
}));
---

<PageLayout title="Movies" description="My personal film diary — watched and watchlist.">
  <div class="pb-16">
    <div class="mb-12">
      <div class="text-[11px] font-medium tracking-[0.08em] uppercase text-[var(--muted-foreground)] opacity-50 mb-2.5 animate-fade-in stagger-1">
        Cinema
      </div>
      <h1 class="text-[28px] font-semibold tracking-[-0.03em] text-[var(--foreground)] mb-2.5 leading-[1.2] animate-fade-in stagger-2">
        Movies
      </h1>
      <p class="text-[13px] text-[var(--muted-foreground)] leading-relaxed tracking-[-0.01em] max-w-[400px] animate-fade-in stagger-3">
        My personal film diary. Films I've watched, thoughts I've had, and what's next on my list.
      </p>
    </div>

    <MoviesGrid movies={movies} client:load />
  </div>
</PageLayout>
