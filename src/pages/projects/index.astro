			{ name: 'Linux', slug: 'linux', icon: 'linux-original' },
			{ name: 'Cloudflare', slug: 'cloudflare', icon: 'cloudflare-original' },
			{ name: 'Vitest', favicon: '/icons/favicons/vitest.png' },
		],
	},
	{
		label: 'Bots & Integrations',
		items: [
			{ name: 'Discord.js', favicon: '/icons/favicons/discordjs.png' },
