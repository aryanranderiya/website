			{ name: 'Next.js', slug: 'nextjs', icon: 'nextjs-original' },
			{ name: 'Astro', slug: 'astro', icon: 'astro-original' },
			{ name: 'TailwindCSS', slug: 'tailwindcss', icon: 'tailwindcss-original' },
			{ name: 'Zustand', favicon: '/icons/favicons/zustand.png' },
