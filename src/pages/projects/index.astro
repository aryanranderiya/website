			{ name: 'Android Studio', slug: 'androidstudio', icon: 'androidstudio-original' },
		],
	},
	{
		label: 'Backend',
		items: [
			{ name: 'FastAPI', slug: 'fastapi', icon: 'fastapi-original' },
			{ name: 'Node.js', slug: 'nodejs', icon: 'nodejs-original' },
			{ name: 'Hono', favicon: '/icons/favicons/hono.png' },
