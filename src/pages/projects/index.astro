const DEVICON_BASE = 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons';
---

<PageLayout
  title="Projects"
  description="Things I have built: web apps, mobile apps, open source, and more."
>
  <div class="pb-16">

  <!-- Header -->
  <div class="mb-10">
    <h1 class="text-heading-1 mb-3 animate-fade-in stagger-2">Projects</h1>
    <p class="text-body animate-fade-in stagger-3">
      A collection of things I have built!
    </p>
  </div>

  <ProjectsGrid projects={projects} client:visible />

  <!-- ── Skills ─────────────────────────────────────────────────── -->
  <section class="mt-16 mb-5">
    <p class="section-header pb-4 animate-fade-in" style="animation-delay:0.05s">Skills</p>
    <div class="flex flex-col gap-6">
      {skillCategories.map((cat) => (
        <div class="grid grid-cols-[96px_1fr] gap-3 items-start">
          <div class="text-[11px] font-medium text-[var(--text-ghost)] pt-1">
            {cat.label}
          </div>
          <div class="flex flex-wrap gap-2">
            {cat.items.map((item) => (
              <div class="flex items-center gap-1.5 bg-[var(--muted-bg)] rounded-full px-2.5 py-[3px]">
                {'favicon' in item ? (
                  <img
                    src={item.favicon}
                    alt={item.name}
                    width="14"
                    height="14"
                    class="w-[14px] h-[14px] shrink-0 rounded-[2px]"
                  />
                ) : item.slug && item.icon ? (
                  <img
                    src={`${DEVICON_BASE}/${item.slug}/${item.icon}.svg`}
                    alt={item.name}
                    width="14"
                    height="14"
                    class="w-[14px] h-[14px] shrink-0"
                    onerror="this.style.display='none';"
                  />
                ) : null}
                <span class="text-[12px] text-[var(--text-secondary)] leading-none">{item.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── GitHub Graph ───────────────────────────────────────────── -->
  <section class="mt-10">
    <GithubGraph client:visible />
  </section>

  </div>
</PageLayout>
