---
import { type CollectionEntry, getCollection } from 'astro:content';
import { GithubIcon, HugeiconsIcon, LinkSquare02Icon } from '@icons';
import { SITE } from '@/constants/site';
import PageLayout from '@/layouts/PageLayout.astro';
import { getTechIconUrl } from '@/utils/techIcons';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

interface Props {
	entry: CollectionEntry<'projects'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const p = entry.data;

const FOLDER_CHIP: Record<string, { color: string; label: string }> = {
	Featured: { color: '#f59e0b', label: 'Featured' },
	Client: { color: '#10b981', label: 'Freelance' },
	Hackathon: { color: '#a78bfa', label: 'Hackathon' },
};

const chip = p.folder ? FOLDER_CHIP[p.folder] : undefined;
const year = new Date(p.date).getFullYear();
const allImages = p.images ?? [];
const canonicalURL = new URL(Astro.url.pathname, SITE.url).toString();

const breadcrumbJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
		{ '@type': 'ListItem', position: 2, name: 'Projects', item: `${SITE.url}/projects` },
		{ '@type': 'ListItem', position: 3, name: p.title, item: canonicalURL },
	],
});

const projectJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: p.title,
	description: p.description,
	url: p.url ?? canonicalURL,
	dateCreated: new Date(p.date).toISOString(),
	author: {
		'@type': 'Person',
		name: SITE.name,
		url: SITE.url,
	},
	...(p.tech && p.tech.length > 0 ? { keywords: p.tech.join(', ') } : {}),
	...(allImages[0]
		? {
				image: allImages[0].startsWith('http')
					? allImages[0]
					: new URL(allImages[0], SITE.url).toString(),
			}
		: {}),
});
const [heroImage, ...galleryImages] = allImages;
---

<PageLayout title={p.title} description={p.description} ogImage={heroImage}>
  <script is:inline type="application/ld+json" set:html={breadcrumbJsonLd} />
  <script is:inline type="application/ld+json" set:html={projectJsonLd} />

  <!-- Breadcrumb -->
  <nav class="flex items-center gap-1.5 mb-8">
    <a
      href="/projects"
      class="text-xs text-[var(--text-ghost)] no-underline transition-colors duration-150 hover:text-[var(--text-muted)]"
    >
      Projects
    </a>
    <span class="text-xs text-[var(--text-ghost)]">/</span>
    <span class="text-xs text-[var(--text-secondary)] tracking-[-0.01em]">{p.title}</span>
  </nav>

  <!-- Header -->
  <header class="mb-9">
    <!-- Badges row -->
    <div class="flex items-center gap-1.5 mb-3.5 flex-wrap">
      {p.status === 'archived' && (
        <span class="text-[10px] px-2 py-[2px] rounded-full bg-[var(--muted-bg)] text-[var(--text-ghost)] tracking-[0.02em]">
          Archived
        </span>
      )}
      <span class="text-[10px] px-2 py-[2px] rounded-full bg-[var(--muted-bg)] text-[var(--text-muted)] tracking-[0.02em] capitalize">
        {p.type}
      </span>
      {chip && (
        <span
          class="text-[10px] px-2 py-[2px] rounded-full bg-[var(--muted-bg)] font-medium tracking-[0.02em]"
          style={`color: ${chip.color};`}
        >
          {chip.label}
        </span>
      )}
      <span class="text-[10px] px-2 py-[2px] rounded-full bg-[var(--muted-bg)] text-[var(--text-ghost)] tracking-[0.02em]">
        {year}
      </span>
    </div>

    <!-- Title + CTA row -->
    <div class="flex items-start justify-between gap-4 mb-4 flex-wrap">
      <h1 class="text-[28px] font-semibold tracking-[-0.04em] text-[var(--text-primary)] leading-[1.15] m-0">
        {p.title}
      </h1>
      <div class="flex items-center gap-2 shrink-0 pt-[3px]">
        {p.github && (
          <a
            href={p.github}
            target="_blank"
            rel="noopener noreferrer"
            class="h-8 px-3 rounded-lg inline-flex items-center gap-1.5 bg-[var(--muted-bg)] text-[var(--text-secondary)] no-underline transition-opacity duration-150 hover:opacity-65 shrink-0 text-xs font-medium tracking-[-0.01em]"
          >
            <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
            </svg>
            View GitHub
          </a>
        )}
        {p.url && (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="h-8 px-3 rounded-lg inline-flex items-center gap-[5px] bg-[var(--text-primary)] text-[var(--background)] no-underline transition-opacity duration-150 hover:opacity-75 shrink-0 text-xs font-medium tracking-[-0.01em]"
          >
            Visit
            <HugeiconsIcon icon={LinkSquare02Icon} size={11} color="currentColor" />
          </a>
        )}
      </div>
    </div>

    <!-- Description -->
    <p class="text-sm text-[var(--text-muted)] leading-[1.7] m-0 max-w-[560px]">
      {p.description}
    </p>
  </header>

  <!-- Tech stack + Tags -->
  <section class="mb-10 flex flex-col gap-5">
    {p.tech && p.tech.length > 0 && (
      <div>
        <div class="text-[10px] font-medium tracking-[0.07em] uppercase text-[var(--text-ghost)] mb-2.5">
          Tech Stack
        </div>
        <div class="flex flex-wrap gap-1.5">
          {p.tech.map(t => {
            const iconUrl = getTechIconUrl(t);
            return (
              <span class="inline-flex items-center gap-[5px] text-[11px] px-2.5 py-1 rounded-full bg-[var(--muted-bg)] text-[var(--text-secondary)]">
                {iconUrl && (
                  <img src={iconUrl} alt="" width="12" height="12" class="shrink-0 object-contain" />
                )}
                {t}
              </span>
            );
          })}
        </div>
      </div>
    )}

    {p.tags && p.tags.filter(tag => !p.tech?.includes(tag)).length > 0 && (
      <div>
        <div class="text-[10px] font-medium tracking-[0.07em] uppercase text-[var(--text-ghost)] mb-2.5">
          Tags
        </div>
        <div class="flex flex-wrap gap-1.5">
          {p.tags.filter(tag => !p.tech?.includes(tag)).map(tag => (
            <span class="text-[11px] px-[9px] py-[3px] rounded-full bg-[var(--muted-bg)] text-[var(--text-muted)]">
              {tag}
            </span>
          ))}
        </div>
      </div>
    )}
  </section>

  <!-- Body content (rendered markdown) -->
  <div class="mb-11 text-sm text-[var(--text-muted)] leading-[1.7] tracking-[-0.01em] [&_p]:mb-[1em] [&_p:last-child]:mb-0">
    <Content />
  </div>

  <!-- Images -->
  {allImages.length > 0 && (
    <section id="project-images" class="mb-11">
      <!-- Hero image -->
      {heroImage && (
        <div class="group relative cursor-pointer rounded-[14px] overflow-hidden bg-[var(--muted-bg)] mb-2">
          <img
            src={heroImage}
            alt={p.title}
            class="w-full h-auto block cursor-pointer transition-[scale,filter] duration-300 ease-out group-hover:scale-[1.04] group-hover:brightness-[1.04]"
            loading="lazy"
          />
        </div>
      )}

      <!-- Gallery grid (remaining images) -->
      {galleryImages.length === 1 && (
        <div class="group relative cursor-pointer rounded-[10px] overflow-hidden bg-[var(--muted-bg)]">
          <img
            src={galleryImages[0]}
            alt={`${p.title} screenshot 2`}
            class="w-full h-auto block cursor-pointer transition-[scale,filter] duration-300 ease-out group-hover:scale-[1.04] group-hover:brightness-[1.04]"
            loading="lazy"
          />
        </div>
      )}
      {galleryImages.length >= 2 && (
        <div class="grid grid-cols-2 max-[600px]:grid-cols-1 gap-2" id="gallery-grid">
          {galleryImages.map((img, i) => (
            <div class="gallery-item group relative cursor-pointer [&.landscape]:col-span-2 rounded-[10px] overflow-hidden bg-[var(--muted-bg)]">
              <img
                src={img}
                alt={`${p.title} screenshot ${i + 2}`}
                class="w-full h-auto block cursor-pointer transition-[scale,filter] duration-300 ease-out group-hover:scale-[1.04] group-hover:brightness-[1.04]"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      )}
    </section>
  )}

  <!-- Video (if present) -->
  {p.video && (
    <section class="mb-11">
      <div class="rounded-[14px] overflow-hidden bg-[var(--muted-bg)] aspect-video">
        <video
          src={p.video}
          controls
          class="w-full h-full block object-cover"
        />
      </div>
    </section>
  )}

</PageLayout>

<script>
  // ── Smart grid: landscape images span both columns ──────────────────────
  const grid = document.getElementById('gallery-grid');
  if (grid) {
    Array.from(grid.querySelectorAll<HTMLElement>('.gallery-item')).forEach(item => {
      const img = item.querySelector('img');
      if (!img) return;
      const applySpan = () => {
        if (img.naturalWidth > 0 && img.naturalHeight > 0 && img.naturalWidth / img.naturalHeight > 1.3)
          item.classList.add('landscape');
      };
      img.complete ? applySpan() : img.addEventListener('load', applySpan, { once: true });
    });
  }

  // ── Lightbox ──────────────────────────���──────────────────────────────────
  const allImgEls = Array.from(
    document.querySelectorAll<HTMLImageElement>('#project-images img')
  );
  const srcs = allImgEls.map(el => el.src);

  if (srcs.length > 0) {
    let currentIndex = 0;
    const DURATION = 180;

    const overlay = document.createElement('div');
    overlay.id = 'lb-overlay';
    overlay.innerHTML = `
      <div id="lb-backdrop"></div>
      <button id="lb-close" aria-label="Close"></button>
      <button id="lb-prev" aria-label="Previous" ${srcs.length < 2 ? 'hidden' : ''}></button>
      <button id="lb-next" aria-label="Next" ${srcs.length < 2 ? 'hidden' : ''}></button>
      <div id="lb-img-wrap"><img id="lb-img" src="" alt="" /></div>
      <div id="lb-counter"></div>
    `;
    document.body.appendChild(overlay);

    const lbImg     = document.getElementById('lb-img') as HTMLImageElement;
    const lbCounter = document.getElementById('lb-counter')!;
    const lbPrev    = document.getElementById('lb-prev')!;
    const lbNext    = document.getElementById('lb-next')!;
    const lbClose   = document.getElementById('lb-close')!;
    const pageContent = document.getElementById('page-content') as HTMLElement | null;

    function updateCounter() {
      lbCounter.textContent = srcs.length > 1 ? `${currentIndex + 1} / ${srcs.length}` : '';
    }

    function showImage(index: number) {
      currentIndex = (index + srcs.length) % srcs.length;
      lbImg.style.opacity = '0';
      lbImg.src = srcs[currentIndex];
      lbImg.onload = () => { lbImg.style.opacity = '1'; };
      updateCounter();
      (lbPrev as HTMLButtonElement).disabled = false;
      (lbNext as HTMLButtonElement).disabled = false;
    }

    function openLightbox(index: number) {
      currentIndex = index;
      showImage(currentIndex);
      overlay.style.display = 'flex';
      requestAnimationFrame(() => { overlay.style.opacity = '1'; });
      document.body.style.overflow = 'hidden';
      if (pageContent) {
        pageContent.style.transition = `filter ${DURATION}ms ease`;
        requestAnimationFrame(() => { pageContent.style.filter = 'blur(12px) brightness(0.6)'; });
      }
    }

    function closeLightbox() {
      overlay.style.opacity = '0';
      setTimeout(() => { overlay.style.display = 'none'; }, DURATION);
      document.body.style.overflow = '';
      if (pageContent) {
        pageContent.style.transition = `filter ${DURATION}ms ease`;
        pageContent.style.filter = 'blur(0px) brightness(1)';
        setTimeout(() => { pageContent.style.filter = ''; pageContent.style.transition = ''; }, DURATION + 20);
      }
    }

    allImgEls.forEach((img, i) => {
      img.addEventListener('click', () => openLightbox(i));
    });

    lbClose.addEventListener('click', closeLightbox);
    document.getElementById('lb-backdrop')!.addEventListener('click', closeLightbox);
    lbPrev.addEventListener('click', () => showImage(currentIndex - 1));
    lbNext.addEventListener('click', () => showImage(currentIndex + 1));

    window.addEventListener('keydown', (e) => {
      if (overlay.style.display !== 'flex') return;
      if (e.key === 'Escape')     closeLightbox();
      if (e.key === 'ArrowLeft')  showImage(currentIndex - 1);
      if (e.key === 'ArrowRight') showImage(currentIndex + 1);
    });
  }
</script>

<style is:global>
  /* Lightbox styles target JS-injected DOM - cannot use Tailwind here */
  #lb-overlay {
    display: none;
    opacity: 0;
    position: fixed;
    inset: 0;
    z-index: 9999;
    align-items: center;
    justify-content: center;
    transition: opacity 180ms ease;
  }

  #lb-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
  }

  #lb-img-wrap {
    position: relative;
    z-index: 1;
    max-width: min(92vw, 1200px);
    max-height: 88vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #lb-img {
    max-width: 100%;
    max-height: 88vh;
    width: auto;
    height: auto;
    border-radius: 10px;
    display: block;
    transition: opacity 140ms ease;
    object-fit: contain;
  }

  #lb-close {
    position: absolute;
    top: 20px;
    right: 20px;
    z-index: 2;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: background 150ms ease;
  }
  #lb-close::before,
  #lb-close::after {
    content: '';
    position: absolute;
    width: 14px;
    height: 1.5px;
    background: currentColor;
    border-radius: 2px;
  }
  #lb-close::before { transform: rotate(45deg); }
  #lb-close::after  { transform: rotate(-45deg); }
  #lb-close:hover { background: rgba(255,255,255,0.2); }

  #lb-prev,
  #lb-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    border: none;
    cursor: pointer;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 150ms ease;
  }
  #lb-prev { left: 20px; }
  #lb-next { right: 20px; }
  #lb-prev::after,
  #lb-next::after {
    content: '';
    width: 8px;
    height: 8px;
    border-top: 1.5px solid currentColor;
    border-right: 1.5px solid currentColor;
    display: block;
  }
  #lb-prev::after { transform: rotate(-135deg) translateX(-1px); }
  #lb-next::after { transform: rotate(45deg) translateX(-1px); }
  #lb-prev:hover,
  #lb-next:hover { background: rgba(255,255,255,0.2); }
  #lb-prev[hidden],
  #lb-next[hidden] { display: none; }

  #lb-counter {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    font-size: 12px;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.04em;
    pointer-events: none;
  }
</style>
