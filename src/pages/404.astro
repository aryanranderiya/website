---
import PageLayout from '@/layouts/PageLayout.astro';
import ButtonLink from '@/components/ui/ButtonLink';
---

<PageLayout title="404 — Not Found" noindex>
  <div class="py-32 text-center">
    <div class="text-8xl mb-8 opacity-20 font-bold tracking-[-0.05em]">404</div>
    <h1 class="text-heading-1 mb-4">Page not found</h1>
    <p class="text-body mb-8">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <ButtonLink
      href="/"
      label="Back home"
      icon="arrow-left"
      variant="accent"
      size="sm"
      client:load
    />
  </div>
</PageLayout>
