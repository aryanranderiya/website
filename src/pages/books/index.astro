---
import { getCollection } from 'astro:content';
import Bookshelf from '@/components/books/Bookshelf';
import PageLayout from '@/layouts/PageLayout.astro';

const bookEntries = await getCollection('books');
const books = bookEntries.map((entry) => ({
	slug: entry.slug,
	title: entry.data.title,
	author: entry.data.author,
	cover: entry.data.cover,
	status: entry.data.status,
	rating: entry.data.rating,
	review: entry.data.review,
	genre: entry.data.genre,
	year: entry.data.year,
	pages: entry.data.pages,
	dateRead: entry.data.dateRead?.toISOString(),
	featured: entry.data.featured,
}));
---

<PageLayout title="Bookshelf" description="Books I have read, am reading, and want to read.">
  <div class="pb-16">
    <div class="mb-10">
      <div class="text-label mb-3 text-[var(--muted-foreground)] animate-fade-in stagger-1">Reading</div>
      <h1 class="text-heading-1 mb-4 animate-fade-in stagger-2">Bookshelf</h1>
      <p class="text-body max-w-lg animate-fade-in stagger-3">
        Books that have shaped how I think. Click any book to read my notes and thoughts.
      </p>
    </div>

    <Bookshelf books={books} client:visible />
  </div>
</PageLayout>
