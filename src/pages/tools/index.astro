---
import ToolsGrid from '@/components/tools/ToolsGrid';
import PageLayout from '@/layouts/PageLayout.astro';
---

<PageLayout title="Tools" description="Apps and tools I use daily and genuinely recommend.">
  <div class="pb-16">
    <div class="mb-10">
      <div class="text-label mb-3 text-[var(--muted-foreground)] animate-fade-in stagger-1">Setup</div>
      <h1 class="text-heading-1 mb-4 animate-fade-in stagger-2">Tools I Like</h1>
      <p class="text-body max-w-lg animate-fade-in stagger-3">
        Apps I reach for every day. Click any icon to read why I use it.
      </p>
    </div>

    <ToolsGrid client:load />
  </div>
</PageLayout>
