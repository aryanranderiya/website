---
import PageLayout from "@/layouts/PageLayout.astro";

const images = Array.from(
  { length: 9 },
  (_, i) => `/media/fallout/${i + 1}.webp`,
);
---

<PageLayout
  title="F4LLOUT Esports"
  description="Graphic design and brand identity work for F4LLOUT Esports — banners, team headers, apparel, and visual identity."
  fullWidth={true}
>
  <!-- Header -->
  <div class="page-container mb-10 pt-6">
    <div class="section-header">Community</div>
    <h1 class="text-heading-1 mb-3">F4LLOUT Esports</h1>
    <p class="text-body max-w-[560px]">
      Brand identity and graphic design work for F4LLOUT Esports. Created team
      banners, social headers, apparel graphics, and promotional materials over
      the course of the organization's branding era.
    </p>

    <!-- Full-width image stack -->
    <div class="w-full mt-5">
      {
        images.map((src, i) => (
          <div class="fallout-img-wrap">
            <img
              src={src}
              alt={`F4LLOUT Esports — ${i + 1}`}
              loading={i === 0 ? "eager" : "lazy"}
              decoding="async"
              class="fallout-img"
            />
          </div>
        ))
      }
    </div>
  </div>
</PageLayout>

<style>
  .fallout-gallery {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .fallout-img-wrap {
    width: 100%;
    line-height: 0;
  }

  .fallout-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }
</style>
