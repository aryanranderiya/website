---
import PageLayout from '@/layouts/PageLayout.astro';
import DesignGallery from '@/components/design/DesignGallery';

const headers = [
  'headers__anya.webp',
  'headers__azrec.webp',
  'headers__f4lloutesports.webp',
  'headers__lumiin.webp',
  'headers__teamflight.webp',
  'headers__tootles.webp',
  'headers__tootles2.webp',
  'headers__txro.webp',
  'headers__w0lfzzybanner0.webp',
  'headers__w0lfzzybanner1.webp',
  'headers__w0lfzzybanner2.webp',
  'headers__w0lfzzybanner3.webp',
  'headers__w0lfzzybanner4.webp',
  'headers__w0lfzzybanner5.webp',
  'headers__zezzy1.webp',
  'headers__zezzy2.webp',
  'headers_cody.webp',
  'headers_f4llout_main_blue.webp',
  'headers_f4llout_main_orange.webp',
  'headers_f4llout_main_other.webp',
];

const apparel = [
  'TshirtBlueRose.webp',
  'TshirtButterfly.webp',
  'TshirtCosmos.webp',
  'TshirtDragon.webp',
  'TshirtEthereal.webp',
  'TshirtFuture.webp',
  'TshirtFuture2.webp',
  'TshirtHope.webp',
  'TshirtInterstellar.webp',
  'TshirtInterstellarOld.webp',
  'TshirtJapan.webp',
  'TshirtMiH.webp',
  'TshirtPorsche.webp',
  'TshirtTime.webp',
  'TshirtYe.webp',
];

const thumbnails = [
  'thumbnail_1.webp',
  'thumbnail_2.webp',
  'thumbnail_3.webp',
  'thumbnail_4.webp',
  'thumbnail_5.webp',
  'thumbnail_6.webp',
  'thumbnail_7.webp',
  'thumbnail_8.webp',
  'thumbnail_9.webp',
  'thumbnail_10.webp',
  'thumbnail_11.webp',
];

const adMockups = [
  'Ad_mockup_1.webp',
  'Ad_mockup_2.webp',
  'Ad_mockup_3.webp',
];
---

<PageLayout title="Graphic Design" description="Visual design work — banners, apparel, thumbnails, and ad mockups.">
  <!-- Header -->
  <div class="mb-10">
    <div class="section-header">Design</div>
    <h1 class="text-heading-1 mb-3">Graphic Design</h1>
    <p class="text-body mb-4">
      A collection of graphic design work — esports banners, apparel graphics, YouTube thumbnails, and ad mockups.
    </p>
    <a
      href="https://www.behance.net/aryanranderiya"
      target="_blank"
      rel="noopener noreferrer"
      class="behance-link"
    >
      <img
        src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/behance/behance-original.svg"
        alt=""
        width="14"
        height="14"
        aria-hidden="true"
      />
      Behance
    </a>
  </div>

  <DesignGallery
    apparel={apparel}
    headers={headers}
    thumbnails={thumbnails}
    adMockups={adMockups}
    client:load
  />
</PageLayout>

<style>
  .behance-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    background: var(--muted-bg);
    border-radius: 999px;
    padding: 5px 12px;
    transition: color 0.15s ease, opacity 0.15s ease;
  }
  .behance-link:hover {
    color: var(--text-secondary);
    opacity: 0.85;
  }
</style>

<style is:global>
  /* Apparel: 3-column grid, 1:1 ratio */
  .apparel-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
  }

  .apparel-item {
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }

  .apparel-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Masonry: 2-column */
  .masonry-2col {
    columns: 2;
    gap: 6px;
  }

  .masonry-item {
    break-inside: avoid;
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: 6px;
  }

  .masonry-img {
    width: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 480px) {
    .apparel-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .masonry-2col {
      columns: 1;
    }
  }
</style>
