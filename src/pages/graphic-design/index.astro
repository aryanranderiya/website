---
import DesignGallery from '@/components/design/DesignGallery';
import PageLayout from '@/layouts/PageLayout.astro';

const headers = [
	'headers__anya.webp',
	'headers__azrec.webp',
	'headers__f4lloutesports.webp',
	'headers__lumiin.webp',
	'headers__teamflight.webp',
	'headers__tootles.webp',
	'headers__tootles2.webp',
	'headers__txro.webp',
	'headers__w0lfzzybanner0.webp',
	'headers__w0lfzzybanner1.webp',
	'headers__w0lfzzybanner2.webp',
	'headers__w0lfzzybanner3.webp',
	'headers__w0lfzzybanner4.webp',
	'headers__w0lfzzybanner5.webp',
	'headers__zezzy1.webp',
	'headers__zezzy2.webp',
	'headers_cody.webp',
	'headers_f4llout_main_blue.webp',
	'headers_f4llout_main_orange.webp',
	'headers_f4llout_main_other.webp',
];

const apparel = [
	'TshirtBlueRose.webp',
	'TshirtButterfly.webp',
	'TshirtCosmos.webp',
	'TshirtDragon.webp',
	'TshirtEthereal.webp',
	'TshirtFuture.webp',
	'TshirtFuture2.webp',
	'TshirtHope.webp',
	'TshirtInterstellar.webp',
	'TshirtInterstellarOld.webp',
	'TshirtJapan.webp',
	'TshirtMiH.webp',
	'TshirtPorsche.webp',
	'TshirtTime.webp',
	'TshirtYe.webp',
];

const thumbnails = [
	'thumbnail_1.webp',
	'thumbnail_2.webp',
	'thumbnail_3.webp',
	'thumbnail_4.webp',
	'thumbnail_5.webp',
	'thumbnail_6.webp',
	'thumbnail_7.webp',
	'thumbnail_8.webp',
	'thumbnail_9.webp',
	'thumbnail_10.webp',
	'thumbnail_11.webp',
];

const adMockups = ['Ad_mockup_1.webp', 'Ad_mockup_2.webp', 'Ad_mockup_3.webp'];
---

<PageLayout
  title="Graphic Design"
  description="Visual design work: banners, apparel, thumbnails, and ad mockups."
>
  <!-- Header -->
  <div class="mb-10">
    <h1 class="text-heading-1 mb-3 animate-fade-in stagger-2">
      Graphic Design
    </h1>
    <p class="text-body mb-4 animate-fade-in stagger-3">
      A collection of graphic design work that i've done in the past.
      <br /> I don't actively design as of now, but I might work on a streetwear brand
      in the future.
    </p>
    <a
      href="https://www.behance.net/aryanranderiya"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 text-xs font-medium text-[var(--text-muted)] no-underline bg-[var(--muted-bg)] rounded-full px-3 py-[5px] transition-[color,opacity] duration-150 hover:text-[var(--text-secondary)] hover:opacity-85"
    >
      <img
        src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/behance/behance-original.svg"
        alt=""
        width="14"
        height="14"
        aria-hidden="true"
      />
      Behance
    </a>
  </div>

  <DesignGallery
    apparel={apparel}
    headers={headers}
    thumbnails={thumbnails}
    adMockups={adMockups}
    client:visible
  />
</PageLayout>
