# Spotify Now Playing widget
# Guide: https://leerob.io/blog/spotify-api-nextjs
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token

# GitHub (optional — for higher rate limits on contribution graph)
GITHUB_TOKEN=your_github_personal_access_token

# Mapbox GL JS — embed map on homepage
# Get a token at https://account.mapbox.com/access-tokens/
PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token
